<%- include("../../partials/header", { pageTitle }) %>
<%- include("../partials/layout-start", { activeSection }) %>

<section class="admin-page-head">
  <div>
    <p class="eyebrow">Project workspace</p>
    <h1><%= project.projectName %></h1>
    <p class="muted">
      Client: <strong><%= project.client?.name || project.clientName || "" %></strong> &middot;
      <span class="tag tag--<%= getBadgeColor(project.status) %>"><%= formatStatus(project.status) %></span>
    </p>
  </div>
  <div class="flex gap-8 flex-wrap">
    <a class="btn btn--outline" href="/admin/projects">Back</a>
    <a class="btn btn--outline" href="/admin/projects/<%= project._id %>/edit">Edit</a>
  </div>
</section>

<% var overdue = project.dueDate && new Date(project.dueDate) < new Date() && project.status !== "completed"; %>
<% if (overdue) { %>
  <div class="overdue-warning mb-16">
    <strong>Overdue</strong> &mdash; This project was due on <%= new Date(project.dueDate).toLocaleDateString("en-IN", { timeZone: "Asia/Kolkata" }) %>.
  </div>
<% } %>

<section class="admin-metrics">
  <article class="card admin-metric"><p class="muted small">Client</p><h2><%= project.client?.name || project.clientName || "" %></h2></article>
  <article class="card admin-metric"><p class="muted small">Editor</p><h2><%= project.assignedEditor?.name || "Unassigned" %></h2></article>
  <article class="card admin-metric"><p class="muted small">Priority</p><h2><span class="priority-dot priority-dot--<%= project.priority %>"></span><span class="capitalize"><%= project.priority %></span></h2></article>
  <article class="card admin-metric"><p class="muted small">Amount</p><h2><%= formatMoney(project.payment?.amount || 0) %></h2></article>
  <article class="card admin-metric"><p class="muted small">Due</p><h2 class="<%= overdue ? '' : '' %>" style="<%= overdue ? 'color:var(--danger)' : '' %>"><%= project.dueDate ? new Date(project.dueDate).toLocaleDateString("en-IN") : "—" %></h2></article>
  <article class="card admin-metric"><p class="muted small">Versions</p><h2><%= project.submissions?.length || 0 %></h2></article>
</section>

<div class="admin-grid--two">
  <% if (!project.assignedEditor && project.status === "pending_assignment") { %>
  <div class="card" style="margin:0">
    <h2 class="h2 mt-0">Assign Editor</h2>
    <form method="post" action="/admin/projects/<%= project._id %>/assign" class="admin-form full-width">
      <div class="form-group">
        <select id="editorId" name="editorId" required>
          <option value="">— Select —</option>
          <% editors.forEach(function(editor) { %>
            <option value="<%= editor._id %>"><%= editor.name %> (<%= editor.availability %>)</option>
          <% }) %>
        </select>
      </div>
      <button class="btn" type="submit">Assign</button>
    </form>
  </div>
  <% } %>

  <div class="card" style="margin:0">
    <h2 class="h2 mt-0">Status</h2>
    <% if (allowedTransitions.length === 0) { %>
      <p class="muted">No further transitions available.</p>
    <% } else { %>
      <form method="post" action="/admin/projects/<%= project._id %>/transition" class="admin-form full-width">
        <div class="form-group">
          <select id="toStatus" name="toStatus" required>
            <option value="">— Move to —</option>
            <% allowedTransitions.forEach(function(status) { %>
              <option value="<%= status %>"><%= formatStatus(status) %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <textarea id="notes" name="notes" rows="1" placeholder="Optional notes"></textarea>
        </div>
        <button class="btn" type="submit">Update Status</button>
      </form>
    <% } %>
    <div class="quick-actions">
      <% allowedTransitions.forEach(function(status) { %>
        <form method="post" action="/admin/projects/<%= project._id %>/transition" class="inline">
          <input type="hidden" name="toStatus" value="<%= status %>" />
          <input type="hidden" name="notes" value="" />
          <button class="quick-action-btn" type="submit"><%= formatStatus(status) %></button>
        </form>
      <% }) %>
    </div>
  </div>
</div>

<% if (project.submissions && project.submissions.length > 0) { %>
  <% var latestSub = project.submissions[project.submissions.length - 1]; %>
  <div class="card admin-panel latest-submission">
    <div class="latest-submission__badge">Latest Submission</div>
    <div class="latest-submission__head">
      <strong>Version <%= latestSub.version %></strong>
      <span class="tag tag--ok">Submitted</span>
    </div>
    <div class="latest-submission__meta">
      <span class="muted small">Submitted: <%= new Date(latestSub.submittedAt).toLocaleString("en-IN", { timeZone: "Asia/Kolkata" }) %></span>
    </div>
    <div class="latest-submission__body">
      <p><strong>Drive Link:</strong> <a href="<%= latestSub.driveLink %>" target="_blank" rel="noopener"><%= latestSub.driveLink %></a></p>
      <% if (latestSub.description) { %><p><strong>Description:</strong> <%= latestSub.description %></p><% } %>
      <% if (latestSub.submittedBy) { %><p class="muted"><strong>Submitted By:</strong> Editor</p><% } %>
    </div>
  </div>
<% } %>

<% if (project.status === "submitted") { %>
  <div class="admin-grid--two">
    <div class="card admin-panel" style="margin:0">
      <h2 class="h2 mt-0">Feedback</h2>
      <p class="muted text-sm">Provide feedback to the editor. This will move the project back to Ongoing.</p>
      <form class="admin-form full-width" id="feedback-form">
        <div class="form-group">
          <label for="feedbackComment">Feedback</label>
          <textarea id="feedbackComment" name="comment" rows="3" placeholder="What changes are needed?"></textarea>
        </div>
        <div class="form-group">
          <label for="feedbackLink">Reference Drive Link <span class="muted">(optional)</span></label>
          <input type="url" id="feedbackLink" name="driveLink" placeholder="https://drive.google.com/..." />
        </div>
        <div class="form-group">
          <label for="feedbackTimestamp">Timestamp <span class="muted">(optional)</span></label>
          <input type="text" id="feedbackTimestamp" name="timestamp" placeholder="e.g. 00:42, 01:22, 02:14-02:38" />
        </div>
        <button class="btn" type="submit">Send Feedback</button>
      </form>
    </div>
    <div class="card" style="margin:0" id="complete-card">
      <h2 class="h2 mt-0">Complete Project</h2>
      <p class="muted text-sm">Mark this project as complete. The editor will be notified.</p>
      <div class="full-width" style="margin-top:auto">
        <button class="btn btn--ok full-width" id="btn-complete">Complete Project</button>
      </div>
    </div>
  </div>
<% } %>

<div class="card admin-panel">
    <h2 class="h2 mt-0">Overview</h2>
  <div class="admin-detail-grid">
    <div><span>Drive Link</span><strong><% if (project.driveLink) { %><a href="<%= project.driveLink %>" target="_blank" rel="noopener"><%= project.driveLink.length > 60 ? project.driveLink.slice(0,60) + "..." : project.driveLink %></a><% } else { %><span class="muted">Not provided</span><% } %></strong></div>
    <% if (project.client?.email) { %><div><span>Client Email</span><strong><%= project.client.email %></strong></div><% } %>
    <% if (project.client?.phone) { %><div><span>Client Phone</span><strong><%= project.client.phone %></strong></div><% } %>
    <div><span>Created by</span><strong><%= project.createdBy?.name || "System" %></strong></div>
    <div><span>Created</span><strong><%= new Date(project.createdAt).toLocaleString("en-IN", { timeZone: "Asia/Kolkata" }) %></strong></div>
    <% if (project.completedAt) { %>
      <div><span>Completed</span><strong><%= new Date(project.completedAt).toLocaleString("en-IN", { timeZone: "Asia/Kolkata" }) %></strong></div>
    <% } %>
    <div><span>Payment Amount</span><strong><%= formatMoney(project.payment?.amount || 0) %></strong></div>
    <div><span>Payment Status</span><strong>
      <% if (project.payment?.status === "paid") { %><span class="tag tag--ok">Paid</span>
      <% } else if (project.payment?.status === "pending" && project.status === "completed") { %><span class="tag tag--pending">Awaiting Payment</span>
      <% } else { %><span class="muted">N/A</span><% } %>
    </strong></div>
    <% if (project.notes) { %>
      <div style="grid-column:1/-1"><span>Notes</span><strong style="white-space:pre-wrap"><%= project.notes %></strong></div>
    <% } %>
  </div>
</div>

<% if (project.status === "completed") { %>
<% var editorUpi = project.assignedEditor?.upiId || ""; %>
<% var editorName = project.assignedEditor?.name || "Editor"; %>
<% var clientName = project.client?.name || project.clientName || ""; %>
<% var waMsg = encodeURIComponent("Hi " + editorName + "%0A%0APayment has been completed.%0A%0AProject: " + project.projectName + "%0AClient: " + clientName + "%0AAmount: ₹" + (project.payment?.amount || 0) + "%0A%0AThank you."); %>
<% var waUrl = "https://wa.me/?text=" + waMsg; %>
<div class="card admin-panel payment-section">
    <h2 class="h2 mt-0">Payment <span class="tag tag--<%= project.payment?.status === 'paid' ? 'ok' : 'pending' %>" style="margin-left:8px"><%= project.payment?.status === 'paid' ? 'Paid' : 'Pending' %></span></h2>
  <div class="payment-details">
    <div class="payment-detail"><span>Project</span><strong><%= project.projectName %></strong></div>
    <div class="payment-detail"><span>Client</span><strong><%= clientName %></strong></div>
    <div class="payment-detail"><span>Editor</span><strong><%= editorName %></strong></div>
    <div class="payment-detail"><span>Amount</span><strong><%= formatMoney(project.payment?.amount || 0) %></strong></div>
    <div class="payment-detail"><span>Editor UPI ID</span><strong><%= editorUpi || '<span class="muted">Not set</span>' %></strong></div>
    <div class="payment-detail"><span>Completed</span><strong><%= project.completedAt ? new Date(project.completedAt).toLocaleString("en-IN", { timeZone: "Asia/Kolkata" }) : "—" %></strong></div>
    <% if (project.payment?.status === "paid") { %>
      <div class="payment-detail"><span>Paid At</span><strong><%= project.payment.paidAt ? new Date(project.payment.paidAt).toLocaleString("en-IN", { timeZone: "Asia/Kolkata" }) : "—" %></strong></div>
      <div class="payment-detail"><span>Paid By</span><strong><%= project.payment.paidBy?.name || "Admin" %></strong></div>
    <% } %>
  </div>
  <% if (project.payment?.status !== "paid") { %>
    <div class="payment-actions">
      <button class="btn btn--ok" id="btn-payment-done">Mark Payment Done</button>
      <% if (editorUpi) { %>
        <a class="btn btn--outline" href="<%= waUrl %>" target="_blank" rel="noopener">Open WhatsApp</a>
      <% } %>
    </div>
  <% } %>
</div>
<% } %>

<% if (project.submissions && project.submissions.length > 0) { %>
<div class="card admin-panel">
    <h2 class="h2 mt-0">Submissions</h2>
  <div style="overflow-x:auto">
      <table class="table" role="table">
      <thead>
        <tr><th scope="col">Version</th><th scope="col">Drive Link</th><th scope="col">Description</th><th scope="col">Submitted By</th><th scope="col">Date</th></tr>
      </thead>
      <tbody>
        <% project.submissions.slice().reverse().forEach(function(sub) { %>
          <tr>
            <td>V<%= sub.version %></td>
            <td><% if (sub.driveLink) { %><a href="<%= sub.driveLink %>" target="_blank" rel="noopener">Link</a><% } else { %><span class="muted">—</span><% } %></td>
            <td><%= sub.description || "—" %></td>
            <td><%= sub.submittedBy?.name || "Editor" %></td>
            <td><%= new Date(sub.submittedAt).toLocaleDateString("en-IN") %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<% } %>

<% if (project.feedback && project.feedback.length > 0) { %>
<div class="card admin-panel">
    <h2 class="h2 mt-0">Feedback History</h2>
  <div style="overflow-x:auto">
    <table class="table" role="table">
      <thead>
        <tr><th scope="col">Version Ref</th><th scope="col">Comment</th><th scope="col">Drive Link</th><th scope="col">Timestamp</th><th scope="col">Created By</th><th scope="col">Date</th></tr>
      </thead>
      <tbody>
        <% project.feedback.slice().reverse().forEach(function(fb) { %>
          <tr>
            <td><%= fb.versionRef ? "V" + fb.versionRef : "—" %></td>
            <td><%= fb.comment || "—" %></td>
            <td><% if (fb.driveLink) { %><a href="<%= fb.driveLink %>" target="_blank" rel="noopener">Link</a><% } else { %><span class="muted">—</span><% } %></td>
            <td><%= fb.timestamp || "—" %></td>
            <td><%= fb.createdBy?.name || "Admin" %></td>
            <td><%= new Date(fb.createdAt).toLocaleDateString("en-IN") %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<% } %>

<div class="card admin-panel">
    <h2 class="h2 mt-0">Project Notifications</h2>
  <% if (!projectNotifications || projectNotifications.length === 0) { %>
    <p class="muted">No notifications for this project.</p>
  <% } else { %>
    <div class="notif-mini-list">
      <% projectNotifications.forEach(function(n) { %>
        <div class="notif-mini-item <%= !n.read ? 'notif-mini-item--unread' : '' %>">
          <div class="notif-mini-item__body">
            <strong><%= n.title %></strong>
            <p><%= n.message %></p>
          </div>
          <div class="notif-mini-item__meta">
            <span class="muted small"><%= new Date(n.createdAt).toLocaleDateString("en-IN") %></span>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<div class="card admin-panel" id="timeline">
    <h2 class="h2 mt-0">Activity Timeline</h2>
  <% if (project.activityTimeline.length === 0) { %>
    <p class="muted">No activity recorded yet.</p>
  <% } else { %>
    <div class="timeline">
      <% project.activityTimeline.slice().reverse().forEach(function(entry) { %>
        <div class="timeline-item">
          <div class="timeline-marker"></div>
          <div class="timeline-content">
            <p class="timeline-action"><strong><%= entry.action %></strong></p>
            <p class="timeline-meta">
              by <%= entry.userName || "System" %>
              <% if (entry.previousStatus && entry.newStatus) { %>
                — <%= formatStatus(entry.previousStatus) %> → <%= formatStatus(entry.newStatus) %>
              <% } %>
            </p>
            <% if (entry.notes) { %><p class="timeline-notes"><%= entry.notes %></p><% } %>
            <p class="timeline-date muted small"><%= new Date(entry.createdAt).toLocaleString("en-IN", { timeZone: "Asia/Kolkata" }) %></p>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<div id="confirm-dialog" class="confirm-overlay" role="dialog" aria-modal="true" aria-labelledby="confirm-title">
  <div class="confirm-dialog">
    <p id="confirm-title"></p>
    <div class="confirm-dialog__actions">
      <button class="btn btn--outline" id="confirm-cancel">Cancel</button>
      <button class="btn" id="confirm-ok">Confirm</button>
    </div>
  </div>
</div>

<script>
(function () {
  var confirmDialog = document.getElementById("confirm-dialog");
  var confirmTitle = document.getElementById("confirm-title");
  var confirmOk = document.getElementById("confirm-ok");
  var confirmCancel = document.getElementById("confirm-cancel");
  var pendingConfirm = null;

  function showConfirm(msg) {
    return new Promise(function (resolve) {
      confirmTitle.textContent = msg;
      confirmDialog.classList.add("is-visible");
      pendingConfirm = resolve;
    });
  }

  confirmOk.addEventListener("click", function () {
    confirmDialog.classList.remove("is-visible");
    if (pendingConfirm) pendingConfirm(true);
    pendingConfirm = null;
  });

  confirmCancel.addEventListener("click", function () {
    confirmDialog.classList.remove("is-visible");
    if (pendingConfirm) pendingConfirm(false);
    pendingConfirm = null;
  });

  confirmDialog.addEventListener("click", function (e) {
    if (e.target === confirmDialog) {
      confirmDialog.classList.remove("is-visible");
      if (pendingConfirm) pendingConfirm(false);
      pendingConfirm = null;
    }
  });

  function showFormError(form, msg) {
    var existing = form.querySelector(".alert-inline");
    if (!existing) {
      existing = document.createElement("div");
      existing.className = "alert-inline alert-inline--error is-visible";
      form.insertBefore(existing, form.querySelector("button"));
    } else {
      existing.classList.add("is-visible");
      existing.classList.remove("alert-inline--success");
      existing.classList.add("alert-inline--error");
    }
    existing.textContent = msg;
    setTimeout(function () { existing.classList.remove("is-visible"); }, 4000);
  }

  var feedbackForm = document.getElementById("feedback-form");
  if (feedbackForm) {
    feedbackForm.addEventListener("submit", function (e) {
      e.preventDefault();
      var btn = feedbackForm.querySelector("button[type=submit]");
      var comment = feedbackForm.querySelector("[name=comment]").value.trim();
      var driveLink = feedbackForm.querySelector("[name=driveLink]").value.trim();
      var timestamp = feedbackForm.querySelector("[name=timestamp]").value.trim();

      btn.disabled = true;
      btn.textContent = "Sending...";

      fetch("/admin/projects/<%= project._id %>/feedback", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ comment: comment, driveLink: driveLink, timestamp: timestamp }),
      })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (data.success) {
            location.reload();
          } else {
            showFormError(feedbackForm, data.error || "Failed to send feedback.");
            btn.disabled = false;
            btn.textContent = "Send Feedback";
          }
        })
        .catch(function () {
          showFormError(feedbackForm, "Network error.");
          btn.disabled = false;
          btn.textContent = "Send Feedback";
        });
    });
  }

  var completeBtn = document.getElementById("btn-complete");
  if (completeBtn) {
    completeBtn.addEventListener("click", function () {
      showConfirm("Mark this project as complete?").then(function (confirmed) {
        if (!confirmed) return;
        completeBtn.disabled = true;
        completeBtn.textContent = "Completing...";

        fetch("/admin/projects/<%= project._id %>/complete", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
        })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            if (data.success) {
              location.reload();
            } else {
              showFormError(completeBtn.closest(".card") || document, data.error || "Failed to complete project.");
              completeBtn.disabled = false;
              completeBtn.textContent = "Complete Project";
            }
          })
          .catch(function () {
            showFormError(completeBtn.closest(".card") || document, "Network error.");
            completeBtn.disabled = false;
            completeBtn.textContent = "Complete Project";
          });
      });
    });
  }

  var paymentBtn = document.getElementById("btn-payment-done");
  if (paymentBtn) {
    paymentBtn.addEventListener("click", function () {
      showConfirm("Mark payment as done? This cannot be undone.").then(function (confirmed) {
        if (!confirmed) return;
        paymentBtn.disabled = true;
        paymentBtn.textContent = "Processing...";

        fetch("/admin/projects/<%= project._id %>/payment-done", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
        })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            if (data.success) {
              location.reload();
            } else {
              showFormError(paymentBtn.parentNode, data.error || "Failed to mark payment.");
              paymentBtn.disabled = false;
              paymentBtn.textContent = "Mark Payment Done";
            }
          })
          .catch(function () {
            showFormError(paymentBtn.parentNode, "Network error.");
            paymentBtn.disabled = false;
            paymentBtn.textContent = "Mark Payment Done";
          });
      });
    });
  }
})();
</script>

<%- include("../partials/layout-end") %>
<%- include("../../partials/footer") %>
