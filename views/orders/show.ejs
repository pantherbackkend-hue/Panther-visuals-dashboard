<%- include("../partials/header", { pageTitle }) %>

<div class="breadcrumb">
  <a href="/projects">My projects</a>
  <span class="muted"> / </span>
  <span>...<%= String(order._id).slice(-6) %></span>
</div>

<% const statusLabel = order.status === "pending_payment" ? "Payment Pending" : order.status === "paid" ? "Pending - awaiting editor" : order.status === "accepted" ? "Assigned" : order.status === "in_progress" ? "In Progress" : order.status === "in_review" ? "In Review" : order.status === "revision" ? "Revision" : order.status === "completed" ? "Completed" : order.status; %>
<% const tagClass = order.status === "completed" ? "ok" : order.status === "in_review" ? "pending" : order.status === "in_progress" ? "pending" : order.status === "accepted" ? "pending" : order.status === "paid" ? "pending" : "muted"; %>
<% const displayLabel = order.status === "cancelled" ? "Project Cancelled" : statusLabel; %>
<% const displayTagClass = order.status === "cancelled" ? "warn" : tagClass; %>
<% const stepIndex = order.status === "completed" ? 5 : order.status === "in_review" || order.status === "revision" ? 4 : order.status === "in_progress" ? 3 : order.status === "accepted" ? 2 : order.status === "paid" ? 2 : 1; %>
<% const isAdjusted = !!(order.adjustedAt); %>
<% const removedItems = isAdjusted ? order.items.filter(function(i) { return i.status === "removed"; }) : []; %>
<% displayLabelAdj = (isAdjusted && order.status !== "completed" && order.status !== "cancelled") ? "Project Updated" : displayLabel; %>
<% displayTagClassAdj = (isAdjusted && order.status !== "completed" && order.status !== "cancelled") ? "warn" : displayTagClass; %>

<div class="card order-detail">
  <div class="order-detail__head">
    <div>
      <p class="eyebrow">Project ...<%= String(order._id).slice(-6) %></p>
      <h1>Project #<%= String(order._id).slice(-6).toUpperCase() %></h1>
    </div>
    <span class="tag tag--<%= displayTagClassAdj %>"><%= displayLabelAdj %></span>
  </div>
  <p class="muted"><%= order.shop?.name || "Workspace" %> &middot; <%= new Date(order.createdAt).toLocaleString("en-IN", {
  timeZone: "Asia/Kolkata"
}) %></p>

  <% if (isAdjusted) { %>
    <div class="adjust-notice">
      <p><strong>Project Updated</strong></p>
      <% if (removedItems.length > 0) { %>
        <p class="muted">Unavailable: <%= removedItems.map(function(i) { return i.name; }).join(", ") %></p>
      <% } %>
      <p class="muted">Refund Amount: &#8377;<%= Number(order.refundAmount || 0).toFixed(2) %></p>
      <p class="muted">Updated Total: &#8377;<%= Number(order.updatedTotal || order.total).toFixed(2) %></p>
      <% if (order.adjustmentReason) { %>
        <p class="muted">Reason: <%= order.adjustmentReason %></p>
      <% } %>
    </div>
  <% } %>

  <% if (order.status !== "cancelled") { %>
    <ol class="progress-tracker" aria-label="Project progress">
      <% [
        ["Project Created", 1],
        ["Assigned to Editor", 2],
        ["In Progress", 3],
        ["In Review", 4],
        ["Completed", 5],
      ].forEach(([label, index]) => { %>
        <li class="progress-tracker__step <%= stepIndex >= index ? "is-complete" : "" %> <%= stepIndex === index ? "is-current" : "" %>">
          <span class="progress-tracker__dot"><% if (stepIndex >= index) { %>&#10003;<% } else { %><%= index %><% } %></span>
          <span><%= label %></span>
        </li>
      <% }) %>
    </ol>
  <% } %>

  <% if (order.status === "paid") { %>
    <p class="muted">Waiting for the editor to accept your project.</p>
  <% } else if (order.status === "accepted") { %>
    <p class="muted">Your project has been assigned to an editor and is being worked on.</p>
  <% } else if (order.status === "in_progress") { %>
    <p class="muted">The editor is currently working on your project.</p>
  <% } else if (order.status === "in_review") { %>
    <p class="muted">Your project is in review. You may request revisions if needed.</p>
    <form method="post" action="/projects/<%= order._id %>/revision-request" class="inline">
      <button class="btn" type="submit">Request Revision</button>
    </form>
  <% } else if (order.status === "revision") { %>
    <p class="muted">The editor has been notified about your revision request.</p>
  <% } else if (order.status === "completed") { %>
    <p class="muted">This project has been completed.</p>
  <% } else if (order.status === "cancelled") { %>
    <p class="muted">Project Cancelled</p>
    <% if (order.refundStatus === "completed") { %>
      <p class="muted">Refund Initiated</p>
    <% } else if (order.refundStatus === "failed") { %>
      <p class="muted">Refund processing issue. Please contact support.</p>
    <% } %>
  <% } else if (order.status === "pending_payment") { %>
    <p class="muted">Complete payment when checkout supports it.</p>
  <% } %>

  <h2 class="h2">Items</h2>
  <ul class="plain-list">
    <% order.items.forEach((line) => { %>
      <li class="<%= line.status === 'removed' ? 'item-removed' : '' %>">
        <%= line.quantity %> x <%= line.name %>
        <% if (line.variantName) { %><span class="muted">(Variant: <%= line.variantName %>)</span><% } %>
        - &#8377;<%= (line.price * line.quantity).toFixed(2) %>
        <% if (line.status === "removed") { %><span class="muted small"> (unavailable)</span><% } %>
      </li>
    <% }) %>
  </ul>
  <p class="cart-total"><strong>Total:</strong> &#8377;<%= (order.updatedTotal || order.total).toFixed(2) %></p>
</div>

<script>
  (function () {
    var orderId = "<%= order._id %>";
    var currentStatus = "<%= order.status %>";
    var wasAdjusted = <%= isAdjusted %>;

    var intervalId = setInterval(async function () {
      try {
        var res = await fetch("/api/orders/" + encodeURIComponent(orderId) + "/status", {
          headers: { Accept: "application/json" },
          credentials: "same-origin",
        });
        if (!res.ok) return;

        var data = await res.json();
        if ((data.status && data.status !== currentStatus) || (data.adjusted && !wasAdjusted)) {
          window.location.reload();
        }
      } catch (e) {
      }
    }, 5000);

    window.addEventListener("beforeunload", function () {
      clearInterval(intervalId);
    });
  })();
</script>

<%- include("../partials/footer") %>
