<%- include("../../partials/header", { pageTitle }) %>
<%- include("../partials/layout-start", { activeSection }) %>

<section class="admin-page-head">
  <div>
    <p class="eyebrow">Project management</p>
    <h1><%= mode === "create" ? "New Project" : "Edit Project" %></h1>
  </div>
  <a class="btn btn--outline" href="/admin/projects">Back to projects</a>
</section>

<div class="card admin-panel">
  <form method="post" action="<%= mode === "create" ? "/admin/projects" : "/admin/projects/" + project._id + "/edit" %>" class="admin-form">
    <div class="form-group">
      <label for="clientName">Client Name *</label>
      <input id="clientName" name="clientName" type="text" required value="<%= project?.client?.name || project?.clientName || "" %>" />
    </div>

    <div class="form-group">
      <label for="clientEmail">Client Email</label>
      <input id="clientEmail" name="clientEmail" type="email" value="<%= project?.client?.email || "" %>" />
    </div>

    <div class="form-group">
      <label for="clientPhone">Client Phone</label>
      <input id="clientPhone" name="clientPhone" type="text" value="<%= project?.client?.phone || "" %>" />
    </div>

    <div class="form-group">
      <label for="projectName">Project Name *</label>
      <input id="projectName" name="projectName" type="text" required value="<%= project?.projectName || "" %>" />
    </div>

    <% if (currentUser.role === "owner" && mode === "create") { %>
    <div class="form-group">
      <label>Assignment Type</label>
      <div style="display:flex;gap:16px;flex-wrap:wrap;padding:8px 0">
        <label style="display:flex;align-items:center;gap:6px;cursor:pointer">
          <input type="radio" name="ownerAssignment" value="" checked onchange="toggleOwnerAssignment()" /> Standard (no assignment)
        </label>
        <label style="display:flex;align-items:center;gap:6px;cursor:pointer">
          <input type="radio" name="ownerAssignment" value="admin" onchange="toggleOwnerAssignment()" /> Assign to JR Admin
        </label>
        <label style="display:flex;align-items:center;gap:6px;cursor:pointer">
          <input type="radio" name="ownerAssignment" value="direct" onchange="toggleOwnerAssignment()" /> Assign directly to Editor
        </label>
      </div>
    </div>

    <div class="form-group" id="ownerAdminGroup" style="display:none">
      <label for="ownerAdmin">Select JR Admin</label>
      <select id="ownerAdmin" name="ownerAdmin">
        <option value="">— Select JR Admin —</option>
        <% (admins || []).forEach(function(admin) { %>
          <option value="<%= admin._id %>"><%= admin.name %> (<%= admin.email %>)</option>
        <% }) %>
      </select>
      <p class="form-help">The JR Admin will assign an editor and manage this project.</p>
    </div>
    <% } %>

    <div class="form-group" id="editorSelectGroup" style="<%= currentUser.role === 'owner' && mode === 'create' ? 'display:none' : '' %>">
      <label for="assignedEditor">Assign Editor</label>
      <select id="assignedEditor" name="assignedEditor">
        <option value="">— Unassigned —</option>
        <% editors.forEach((editor) => { %>
          <option value="<%= editor._id %>" <%= project?.assignedEditor && String(project.assignedEditor._id || project.assignedEditor) === String(editor._id) ? "selected" : "" %>><%= editor.name %> (<%= editor.availability %>)</option>
        <% }) %>
      </select>
      <p class="form-help">Editors on leave or fully occupied cannot be assigned.</p>
    </div>

    <% if (currentUser.role === "owner" || (project && !project.ownerAssignment)) { %>
    <div class="form-group">
      <label for="paymentAmount">Client Amount (₹)</label>
      <input id="paymentAmount" name="paymentAmount" type="number" min="0" step="0.01" value="<%= project?.payment?.clientAmount || project?.payment?.amount || project?.paymentAmount || "" %>" />
    </div>
    <% } %>

    <% if (currentUser.role === "owner" || project?.ownerAssignment) { %>
    <div class="form-group">
      <label for="editorAmount">Editor Amount (₹)</label>
      <input id="editorAmount" name="editorAmount" type="number" min="0" step="0.01" value="<%= project?.payment?.editorAmount || "" %>" />
      <p class="form-help">Amount paid to the editor. Profit = Client Amount - Editor Amount.</p>
    </div>
    <% } %>

    <% if (currentUser.role !== "owner" && !(project && project.ownerAssignment)) { %>
    <div class="form-group">
      <label for="paymentAmount">Payment Amount (₹)</label>
      <input id="paymentAmount" name="paymentAmount" type="number" min="0" step="0.01" value="<%= project?.payment?.amount || project?.paymentAmount || "" %>" />
    </div>
    <% } %>

    <div class="form-group">
      <label for="priority">Priority</label>
      <select id="priority" name="priority">
        <option value="low" <%= project?.priority === "low" ? "selected" : "" %>>Low</option>
        <option value="medium" <%= (!project?.priority || project?.priority === "medium") ? "selected" : "" %>>Medium</option>
        <option value="high" <%= project?.priority === "high" ? "selected" : "" %>>High</option>
        <option value="urgent" <%= project?.priority === "urgent" ? "selected" : "" %>>Urgent</option>
      </select>
    </div>

    <div class="form-group">
      <label for="dueDate">Due Date</label>
      <input id="dueDate" name="dueDate" type="date" value="<%= project?.dueDate ? new Date(project.dueDate).toISOString().split("T")[0] : "" %>" />
    </div>

    <div class="form-group">
      <label for="driveLink">Drive Link</label>
      <input id="driveLink" name="driveLink" type="url" placeholder="https://drive.google.com/..." value="<%= project?.driveLink || "" %>" />
    </div>

    <div class="form-group">
      <label for="notes">Notes</label>
      <textarea id="notes" name="notes" rows="4"><%= project?.notes || "" %></textarea>
    </div>

    <div class="form-actions">
      <button class="btn" type="submit"><%= mode === "create" ? "Create Project" : "Update Project" %></button>
      <a class="btn btn--outline" href="/admin/projects">Cancel</a>
    </div>
  </form>
</div>

<script>
function toggleOwnerAssignment() {
  var radios = document.querySelectorAll('input[name="ownerAssignment"]');
  var selected;
  radios.forEach(function(r) { if (r.checked) selected = r.value; });

  var adminGroup = document.getElementById('ownerAdminGroup');
  var editorGroup = document.getElementById('editorSelectGroup');

  if (adminGroup) adminGroup.style.display = selected === 'admin' ? '' : 'none';
  if (editorGroup) editorGroup.style.display = selected === 'direct' ? '' : (selected === '' ? '' : 'none');
}
<%= currentUser.role === 'owner' && mode === 'create' ? 'toggleOwnerAssignment();' : '' %>
</script>

<%- include("../partials/layout-end") %>
<%- include("../../partials/footer") %>
