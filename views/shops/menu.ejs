<%- include("../partials/header", { pageTitle }) %>

<div class="breadcrumb">
  <a href="/shops">Workspaces</a>
  <span class="muted"> / </span>
  <span><%= shop.name %></span>
</div>

<section class="hero hero--compact">
  <h1><%= shop.name %></h1>
  <p>
    <span class="tag <%= shop.isOpen ? "tag--ok" : "tag--warn" %>">
      <%= shop.isOpen ? "Open" : "Closed" %>
    </span>
  </p>
  <% if (shop.description) { %>
    <p class="muted"><%= shop.description %></p>
  <% } %>
</section>

<% if (!menuItems.length) { %>
  <div class="card" style="text-align:center;padding:48px 24px;">
    <h2 style="margin:0 0 8px;">No assets yet</h2>
    <p class="muted">This workspace hasn't added any assets yet. Check back later!</p>
  </div>
<% } else { %>
  <%- include("../partials/menu-table", { mode: "student", items: menuItems, shop: shop }) %>
<% } %>

<%- include("../partials/footer") %>
