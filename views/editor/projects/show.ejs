<%- include("../../partials/header", { pageTitle }) %>

<a href="/editor/projects" class="back-link">← Back to projects</a>

<section class="project-header">
  <div class="project-header__info">
    <h1 class="project-header__name"><%= project.projectName %></h1>
    <div class="project-header__meta">
      <span class="project-header__meta-item">
        <span class="meta-badge meta-badge--<%= project.status === 'ongoing' ? 'ongoing' : project.status === 'submitted' ? 'submitted' : project.status === 'completed' ? 'completed' : 'assigned' %>">
          <%= formatStatus(project.status) %>
        </span>
      </span>
      <span class="project-header__meta-divider"></span>
      <span class="project-header__meta-item">
        <span class="meta-badge meta-badge--<%= project.priority %>">
          <span class="priority-dot" style="margin:0;margin-right:4px;"></span>
          <%= project.priority %>
        </span>
      </span>
      <span class="project-header__meta-divider"></span>
      <span class="project-header__meta-item">
        Client: <strong><%= project.client?.name || project.clientName || "" %></strong>
      </span>
      <% if (project.dueDate) { %>
        <span class="project-header__meta-divider"></span>
        <span class="project-header__meta-item">
          Due: <strong><%= new Date(project.dueDate).toLocaleDateString("en-IN") %></strong>
        </span>
      <% } %>
      <span class="project-header__meta-divider"></span>
      <span class="project-header__meta-item project-header__project-id">#<%= String(project._id).slice(-6).toUpperCase() %></span>
    </div>
  </div>
</section>

<% var overdue = project.dueDate && new Date(project.dueDate) < new Date() && project.status !== "completed"; %>
<% if (overdue) { %>
  <div class="overdue-banner">
    <strong>Overdue</strong> &mdash; This project was due on <%= new Date(project.dueDate).toLocaleDateString("en-IN", { timeZone: "Asia/Kolkata" }) %>.
  </div>
<% } %>

<section class="editor-workspace">

  <!-- ═══ LEFT COLUMN ═══ -->
  <div class="editor-workspace__main">

    <!-- ── Project Details ── -->
    <div class="info-card">
      <div class="info-card__header">
        <h2 class="info-card__title">Project Details</h2>
      </div>
      <div class="detail-grid">
        <div class="detail-group">
          <h3 class="detail-group__title">Client</h3>
          <div class="detail-row">
            <span class="detail-row__label">Name</span>
            <span class="detail-row__value"><%= project.client?.name || project.clientName || "" %></span>
          </div>
          <% if (project.client?.email) { %>
          <div class="detail-row">
            <span class="detail-row__label">Email</span>
            <span class="detail-row__value"><%= project.client.email %></span>
          </div>
          <% } %>
          <% if (project.client?.phone) { %>
          <div class="detail-row">
            <span class="detail-row__label">Phone</span>
            <span class="detail-row__value"><%= project.client.phone %></span>
          </div>
          <% } %>
        </div>
        <div class="detail-group">
          <h3 class="detail-group__title">Project</h3>
          <div class="detail-row">
            <span class="detail-row__label">Payment Amount</span>
            <span class="detail-row__value"><%= formatMoney(project.payment?.amount || 0) %></span>
          </div>
          <div class="detail-row">
            <span class="detail-row__label">Status</span>
            <span class="detail-row__value">
              <span class="meta-badge meta-badge--<%= project.status === 'ongoing' ? 'ongoing' : project.status === 'submitted' ? 'submitted' : project.status === 'completed' ? 'completed' : 'assigned' %>" style="font-size:10px;padding:2px 8px">
                <%= formatStatus(project.status) %>
              </span>
            </span>
          </div>
          <div class="detail-row">
            <span class="detail-row__label">Created</span>
            <span class="detail-row__value"><%= new Date(project.createdAt).toLocaleDateString("en-IN") %></span>
          </div>
          <div class="detail-row">
            <span class="detail-row__label">Updated</span>
            <span class="detail-row__value"><%= new Date(project.updatedAt).toLocaleDateString("en-IN") %></span>
          </div>
        </div>
        <div class="detail-group">
          <h3 class="detail-group__title">Source</h3>
          <div class="detail-row detail-row--full">
            <span class="detail-row__label">Drive Link</span>
            <span class="detail-row__value">
              <% if (project.driveLink) { %><a href="<%= project.driveLink %>" target="_blank" rel="noopener"><%= project.driveLink.length > 40 ? project.driveLink.slice(0,40) + "..." : project.driveLink %></a><% } else { %><span class="muted">Not provided</span><% } %>
            </span>
          </div>
        </div>
        <% if (project.notes) { %>
        <div class="detail-group detail-group--notes">
          <h3 class="detail-group__title">Notes</h3>
          <div class="detail-row detail-row--full detail-row--notes">
            <span class="detail-row__value"><%= project.notes %></span>
          </div>
        </div>
        <% } %>
      </div>
    </div>

    <!-- ── Submission History ── -->
    <div class="info-card">
      <div class="info-card__header">
        <h2 class="info-card__title">Submission History</h2>
        <% if (project.submissions && project.submissions.length > 0) { %>
          <span class="info-card__count"><%= project.submissions.length %> version<%= project.submissions.length !== 1 ? 's' : '' %></span>
        <% } %>
      </div>

      <% if (!project.submissions || project.submissions.length === 0) { %>
        <div class="submission-empty">
          <div class="submission-empty__icon">📁</div>
          <p class="submission-empty__text">No submissions yet.</p>
        </div>
      <% } else { %>
        <div class="submission-table-wrapper">
          <table class="submission-table">
            <thead>
              <tr>
                <th>Version</th>
                <th>Date</th>
                <th>Drive Link</th>
                <th>Description</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% project.submissions.slice().reverse().forEach(function(s, idx) { %>
                <tr>
                  <td>
                    <div class="version-cell">
                      <span class="version-badge <% if (idx === 0) { %>version-badge--latest<% } %>">V<%= s.version %></span>
                    </div>
                  </td>
                  <td><span class="date-cell"><%= new Date(s.submittedAt).toLocaleDateString("en-IN", { timeZone: "Asia/Kolkata" }) %></span></td>
                  <td><a href="<%= s.driveLink %>" target="_blank" rel="noopener" class="drive-link-cell"><%= s.driveLink.length > 35 ? s.driveLink.slice(0,35) + "..." : s.driveLink %></a></td>
                  <td><span class="desc-cell"><%= s.description || "—" %></span></td>
                  <td><span class="status-tag">Submitted</span></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <!-- ── Activity Timeline (preserved) ── -->
    <div class="timeline-card" id="timeline">
      <div class="info-card__header" style="margin-bottom:16px;padding-bottom:12px;">
        <h2 class="info-card__title">Activity Timeline</h2>
      </div>
      <% if (project.activityTimeline.length === 0) { %>
        <p class="timeline-empty">No activity recorded yet.</p>
      <% } else { %>
        <div class="timeline">
          <% project.activityTimeline.slice().reverse().forEach(function(entry) { %>
            <div class="timeline-item">
              <div class="timeline-marker"></div>
              <div class="timeline-content">
                <p class="timeline-action"><strong><%= entry.action %></strong></p>
                <p class="timeline-meta">
                  by <%= entry.userName || "System" %>
                  <% if (entry.previousStatus && entry.newStatus) { %>
                    — <%= formatStatus(entry.previousStatus) %> → <%= formatStatus(entry.newStatus) %>
                  <% } %>
                </p>
                <% if (entry.notes) { %><p class="timeline-notes"><%= entry.notes %></p><% } %>
                <p class="timeline-date muted small"><%= new Date(entry.createdAt).toLocaleString("en-IN", { timeZone: "Asia/Kolkata" }) %></p>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>

  <!-- ═══ RIGHT COLUMN ═══ -->
  <div class="editor-workspace__sidebar">

    <!-- ── Upload Panel ── -->
    <% if (project.status === "ongoing") { %>
    <div class="upload-panel" style="margin-top:0">
      <h2 class="upload-panel__title">Submit New Version</h2>
      <p class="upload-panel__subtitle">Version <strong><%= (project.submissions?.length || 0) + 1 %></strong></p>
      <form id="submit-form">
        <div class="form-group">
          <label for="driveLink">Drive Link *</label>
          <input type="url" id="driveLink" name="driveLink" placeholder="https://drive.google.com/..." required />
        </div>
        <div class="form-group">
          <label for="description">Description</label>
          <textarea id="description" name="description" rows="2" placeholder="What's in this submission?"></textarea>
        </div>
        <button class="btn btn--accent btn--accent-full" type="submit">Upload Version <%= (project.submissions?.length || 0) + 1 %></button>
      </form>
    </div>
    <% } %>

    <!-- ── Feedback Panel ── -->
    <div class="info-card">
      <div class="info-card__header">
        <h2 class="info-card__title">Feedback</h2>
      </div>

      <% if (!project.feedback || project.feedback.length === 0) { %>
        <div class="feedback-empty">
          <div class="feedback-empty__icon">💬</div>
          <p class="feedback-empty__text">No feedback yet.</p>
        </div>
      <% } else { %>
        <% 
          var groupedFeedback = {};
          project.feedback.forEach(function(f) {
            var v = f.versionRef || 0;
            if (!groupedFeedback[v]) groupedFeedback[v] = [];
            groupedFeedback[v].push(f);
          });
          var versionKeys = Object.keys(groupedFeedback).sort(function(a, b) { return Number(b) - Number(a); });
        %>
        <div class="feedback-list">
          <% versionKeys.forEach(function(v) { %>
            <% var fbList = groupedFeedback[v]; %>
            <% fbList.slice().reverse().forEach(function(f, idx) { %>
              <div class="feedback-card <% if (idx === 0 && v === versionKeys[0]) { %>feedback-card--latest<% } %>">
                <div class="feedback-card__head">
                  <div class="feedback-card__author">
                    <span class="feedback-card__avatar"><%= (f.createdBy?.name || "A").charAt(0).toUpperCase() %></span>
                    <div>
                      <span class="feedback-card__author-name"><%= f.createdBy?.name || "Admin" %></span>
                      <div class="feedback-card__meta">
                        <span class="feedback-card__version"><%= v %></span>
                        <% if (idx === 0 && v === versionKeys[0]) { %>
                          <span class="feedback-card__latest-badge">Latest</span>
                        <% } %>
                      </div>
                    </div>
                  </div>
                  <div class="feedback-card__meta">
                    <span><%= new Date(f.createdAt).toLocaleDateString("en-IN", { timeZone: "Asia/Kolkata" }) %></span>
                  </div>
                </div>
                <div class="feedback-card__body">
                  <% if (f.comment) { %>
                    <p class="feedback-card__text"><%= f.comment %></p>
                  <% } %>
                  <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap;">
                    <% if (f.driveLink) { %>
                      <a href="<%= f.driveLink %>" target="_blank" rel="noopener" class="feedback-card__link">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                          Reference Link
                        </a>
                      <% } %>
                      <% if (f.timestamp) { %>
                        <span class="feedback-card__timestamp">
                          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                          <%= f.timestamp %>
                        </span>
                      <% } %>
                  </div>
                </div>
              </div>
            <% }); %>
          <% }); %>
        </div>
      <% } %>
    </div>

    <!-- ── Need Help Card ── -->
    <div class="help-card">
      <div class="help-card__icon">?</div>
      <h3 class="help-card__title">Need Help?</h3>
      <p class="help-card__text">Contact the admin if you need assistance or clarification.</p>
      <a href="/editor/profile" class="btn btn--outline">Contact Admin</a>
    </div>

  </div>
</section>

<script>
  (function () {
    var form = document.getElementById("submit-form");
    if (!form) return;

    form.addEventListener("submit", function (e) {
      e.preventDefault();
      var btn = form.querySelector("button[type=submit]");
      var driveLink = form.querySelector("[name=driveLink]").value.trim();
      var description = form.querySelector("[name=description]").value.trim();

      if (!driveLink) {
        showFormError(form, "Drive link is required.");
        return;
      }

      btn.disabled = true;
      btn.textContent = "Submitting...";

      fetch("/editor/projects/<%= project._id %>/submit", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ driveLink: driveLink, description: description }),
      })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (data.success) {
            location.reload();
          } else {
            showFormError(form, data.error || "Failed to submit.");
            btn.disabled = false;
            btn.textContent = "Upload Version <%= (project.submissions?.length || 0) + 1 %>";
          }
        })
        .catch(function () {
          showFormError(form, "Network error.");
          btn.disabled = false;
          btn.textContent = "Upload Version <%= (project.submissions?.length || 0) + 1 %>";
        });
    });

    function showFormError(form, msg) {
      var existing = form.querySelector(".alert-inline");
      if (!existing) {
        existing = document.createElement("div");
        existing.className = "alert-inline alert-inline--error is-visible";
        form.insertBefore(existing, form.querySelector("button"));
      } else {
        existing.classList.add("is-visible");
        existing.classList.remove("alert-inline--success");
        existing.classList.add("alert-inline--error");
      }
      existing.textContent = msg;
      setTimeout(function () { existing.classList.remove("is-visible"); }, 4000);
    }
  })();
</script>

<%- include("../../partials/footer") %>