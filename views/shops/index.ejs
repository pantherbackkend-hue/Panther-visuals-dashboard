<%- include("../partials/header", { pageTitle }) %>

<section class="hero">
  <h1>Workspaces</h1>
  <p class="muted">Browse available workspaces.</p>
</section>

<% if (!shops.length) { %>
  <div class="card">
    <p>No workspaces are listed yet.</p>
  </div>
<% } else { %>
  <div class="grid grid--shops">
    <% shops.forEach((s) => { %>
      <a class="card card--link" href="/workspaces/<%= s.slug %>">
        <h2 class="card__title"><%= s.name %></h2>
        <% if (s.description) { %>
          <p class="muted card__desc"><%= s.description %></p>
        <% } %>
        <span class="btn btn--small">View assets</span>
      </a>
    <% }) %>
  </div>
<% } %>

<%- include("../partials/footer") %>
