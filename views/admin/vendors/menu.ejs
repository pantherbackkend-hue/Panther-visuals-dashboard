<%- include("../../partials/header", { pageTitle }) %>
<%- include("../partials/layout-start", { activeSection }) %>

<div class="card" style="border-left: 4px solid var(--c-primary, #4361ee);">
  <div class="row row--split" style="align-items: center;">
    <div>
      <p style="margin: 0; font-weight: 600;">
        Managing assets for: <%= vendor.name %>
      </p>
      <p style="margin: 4px 0 0; font-size: 0.9em; color: var(--c-muted, #888);">
        <%= vendor.email %> &middot; <%= shop.name || "Unassigned workspace" %>
      </p>
    </div>
    <div class="row" style="gap: 8px;">
      <a class="btn btn--small" href="/admin/editors/<%= vendor._id %>/assets/import">Import Assets</a>
      <a class="btn btn--small btn--outline" href="/admin/assets">&larr; Back to Manage Assets</a>
    </div>
  </div>
</div>

<%- include("../../partials/menu-manager", {
  shop,
  menuItems,
  createAction: "/admin/editors/" + vendor._id + "/assets",
  apiUrl: "/admin/editors/" + vendor._id + "/assets",
  showShopToggle: true,
  shopToggleAction: "/admin/editors/" + vendor._id + "/shop/toggle",
}) %>

<%- include("../partials/layout-end") %>
<%- include("../../partials/footer") %>
