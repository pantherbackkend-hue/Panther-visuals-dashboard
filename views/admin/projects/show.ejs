<%- include("../../partials/header", { pageTitle }) %>
<%- include("../partials/layout-start", { activeSection }) %>

<section class="admin-page-head">
  <div>
    <p class="eyebrow">Project workspace</p>
    <h1><%= project.projectName %></h1>
    <p class="muted">
      Client: <strong><%= project.clientName %></strong> &middot;
      <span class="tag tag--<%= getBadgeColor(project.status) %>"><%= formatStatus(project.status) %></span>
    </p>
  </div>
  <div style="display:flex;gap:8px;flex-wrap:wrap">
    <a class="btn btn--outline" href="/admin/projects">Back</a>
    <a class="btn btn--outline" href="/admin/projects/<%= project._id %>/edit">Edit</a>
  </div>
</section>

<% var overdue = project.dueDate && new Date(project.dueDate) < new Date() && !["completed","paid","archived","waiting_for_payment"].includes(project.status); %>
<% if (overdue) { %>
  <div class="overdue-warning" style="margin-bottom:16px">
    <strong>Overdue</strong> &mdash; This project was due on <%= new Date(project.dueDate).toLocaleDateString("en-IN", { timeZone: "Asia/Kolkata" }) %>.
  </div>
<% } %>

<section class="admin-metrics">
  <article class="card admin-metric"><p class="muted small">Client</p><h2><%= project.clientName %></h2></article>
  <article class="card admin-metric"><p class="muted small">Editor</p><h2><%= project.assignedEditor?.name || "Unassigned" %></h2></article>
  <article class="card admin-metric"><p class="muted small">Priority</p><h2><span class="priority-dot priority-dot--<%= project.priority %>"></span><span style="text-transform:capitalize"><%= project.priority %></span></h2></article>
  <article class="card admin-metric"><p class="muted small">Amount</p><h2><%= formatMoney(project.paymentAmount) %></h2></article>
  <article class="card admin-metric"><p class="muted small">Due</p><h2 style="<%= overdue ? 'color:var(--danger)' : '' %>"><%= project.dueDate ? new Date(project.dueDate).toLocaleDateString("en-IN") : "—" %></h2></article>
  <article class="card admin-metric"><p class="muted small">Revisions</p><h2><%= project.revisionCounter %></h2></article>
</section>

<div class="admin-grid--two">
  <% if (!project.assignedEditor && ["new_project","pending_assignment"].includes(project.status)) { %>
  <div class="card" style="margin:0">
    <h2 class="h2" style="margin-top:0">Assign Editor</h2>
    <form method="post" action="/admin/projects/<%= project._id %>/assign" class="admin-form" style="max-width:100%">
      <div class="form-group">
        <select id="editorId" name="editorId" required>
          <option value="">— Select —</option>
          <% editors.forEach(function(editor) { %>
            <option value="<%= editor._id %>"><%= editor.name %> (<%= editor.availability %>)</option>
          <% }) %>
        </select>
      </div>
      <button class="btn" type="submit">Assign</button>
    </form>
  </div>
  <% } %>

  <div class="card" style="margin:0">
    <h2 class="h2" style="margin-top:0">Status</h2>
    <% if (allowedTransitions.length === 0) { %>
      <p class="muted">No further transitions available.</p>
    <% } else { %>
      <form method="post" action="/admin/projects/<%= project._id %>/transition" class="admin-form" style="max-width:100%">
        <div class="form-group">
          <select id="toStatus" name="toStatus" required>
            <option value="">— Move to —</option>
            <% allowedTransitions.forEach(function(status) { %>
              <option value="<%= status %>"><%= formatStatus(status) %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <textarea id="notes" name="notes" rows="1" placeholder="Optional notes"></textarea>
        </div>
        <button class="btn" type="submit">Update Status</button>
      </form>
    <% } %>
    <div class="quick-actions" style="margin-top:8px">
      <% allowedTransitions.forEach(function(status) { %>
        <form method="post" action="/admin/projects/<%= project._id %>/transition" style="display:inline">
          <input type="hidden" name="toStatus" value="<%= status %>" />
          <input type="hidden" name="notes" value="" />
          <button class="quick-action-btn" type="submit"><%= formatStatus(status) %></button>
        </form>
      <% }) %>
    </div>
  </div>
</div>

<div class="card admin-panel">
  <h2 class="h2" style="margin-top:0">Overview</h2>
  <div class="admin-detail-grid">
    <div><span>Drive Link</span><strong><% if (project.driveLink) { %><a href="<%= project.driveLink %>" target="_blank" rel="noopener"><%= project.driveLink.length > 60 ? project.driveLink.slice(0,60) + "..." : project.driveLink %></a><% } else { %><span class="muted">Not provided</span><% } %></strong></div>
    <div><span>Created by</span><strong><%= project.createdBy?.name || "System" %></strong></div>
    <div><span>Created</span><strong><%= new Date(project.createdAt).toLocaleString("en-IN", { timeZone: "Asia/Kolkata" }) %></strong></div>
    <% if (project.completedAt) { %>
      <div><span>Completed</span><strong><%= new Date(project.completedAt).toLocaleString("en-IN", { timeZone: "Asia/Kolkata" }) %></strong></div>
    <% } %>
    <div><span>Payment Amount</span><strong><%= formatMoney(project.paymentAmount) %></strong></div>
    <div><span>Payment Status</span><strong>
      <% if (project.status === "paid") { %><span class="tag tag--ok">Paid</span>
      <% } else if (project.status === "waiting_for_payment") { %><span class="tag tag--pending">Awaiting Payment</span>
      <% } else { %><span class="muted">N/A</span><% } %>
    </strong></div>
    <% if (project.notes) { %>
      <div style="grid-column:1/-1"><span>Notes</span><strong style="white-space:pre-wrap"><%= project.notes %></strong></div>
    <% } %>
  </div>
</div>

<% if (project.revisionHistory.length > 0) { %>
<div class="card admin-panel">
  <h2 class="h2" style="margin-top:0">Revision History</h2>
  <div style="overflow-x:auto">
    <table class="table">
      <thead>
        <tr><th>#</th><th>Requested By</th><th>Notes</th><th>Status</th><th>Date</th></tr>
      </thead>
      <tbody>
        <% project.revisionHistory.forEach(function(rev) { %>
          <tr>
            <td><%= rev.revisionNumber %></td>
            <td><%= rev.requestedBy?.name || "Admin" %></td>
            <td><%= rev.notes || "—" %></td>
            <td><span class="tag tag--<%= rev.completedAt ? "ok" : "pending" %>"><%= rev.completedAt ? "Done" : "Open" %></span></td>
            <td><%= new Date(rev.createdAt).toLocaleDateString("en-IN") %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<% } %>

<div class="card admin-panel">
  <h2 class="h2" style="margin-top:0">Project Notifications</h2>
  <% if (!projectNotifications || projectNotifications.length === 0) { %>
    <p class="muted">No notifications for this project.</p>
  <% } else { %>
    <div class="notif-mini-list">
      <% projectNotifications.forEach(function(n) { %>
        <div class="notif-mini-item <%= !n.read ? 'notif-mini-item--unread' : '' %>">
          <div class="notif-mini-item__body">
            <strong><%= n.title %></strong>
            <p><%= n.message %></p>
          </div>
          <div class="notif-mini-item__meta">
            <span class="muted small"><%= new Date(n.createdAt).toLocaleDateString("en-IN") %></span>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<div class="card admin-panel" id="timeline">
  <h2 class="h2" style="margin-top:0">Activity Timeline</h2>
  <% if (project.activityTimeline.length === 0) { %>
    <p class="muted">No activity recorded yet.</p>
  <% } else { %>
    <div class="timeline">
      <% project.activityTimeline.slice().reverse().forEach(function(entry) { %>
        <div class="timeline-item">
          <div class="timeline-marker"></div>
          <div class="timeline-content">
            <p class="timeline-action"><strong><%= entry.action %></strong></p>
            <p class="timeline-meta">
              by <%= entry.userName || "System" %>
              <% if (entry.previousStatus && entry.newStatus) { %>
                — <%= formatStatus(entry.previousStatus) %> → <%= formatStatus(entry.newStatus) %>
              <% } %>
            </p>
            <% if (entry.notes) { %><p class="timeline-notes"><%= entry.notes %></p><% } %>
            <p class="timeline-date muted small"><%= new Date(entry.createdAt).toLocaleString("en-IN", { timeZone: "Asia/Kolkata" }) %></p>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<%- include("../partials/layout-end") %>
<%- include("../../partials/footer") %>
