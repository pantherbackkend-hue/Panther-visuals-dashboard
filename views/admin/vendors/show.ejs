<%- include("../../partials/header", { pageTitle }) %>
<%- include("../partials/layout-start", { activeSection }) %>

<section class="admin-page-head">
  <div>
    <p class="eyebrow">Editor</p>
    <h1><%= vendor.name %></h1>
    <p class="muted"><%= vendor.email %></p>
  </div>
  <div class="admin-actions">
    <a class="btn btn--outline" href="/admin/editors/<%= vendor._id %>/edit">Edit</a>
    <form method="post" action="/admin/editors/<%= vendor._id %>/toggle" class="inline" onsubmit="return confirm('Toggle this editor?')">
      <button class="btn btn--ghost" type="submit"><%= vendor.isActive ? "Disable" : "Enable" %></button>
    </form>
    <form method="post" action="/admin/editors/<%= vendor._id %>/delete" class="inline" onsubmit="return confirm('Delete this editor?')">
      <button class="btn btn--danger" type="submit">Delete</button>
    </form>
  </div>
</section>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:2rem">
  <div class="card">
    <h3>Details</h3>
    <table class="table table--details">
      <tr><td>Status</td><td><span class="tag tag--<%= vendor.isActive === false ? 'danger' : 'ok' %>"><%= vendor.isActive === false ? "Disabled" : "Active" %></span></td></tr>
      <tr><td>Role</td><td><%= vendor.role %></td></tr>
      <tr><td>UPI ID</td><td><%= vendor.upiId || '<span class="muted">Not set</span>' %></td></tr>
      <tr><td>Joined</td><td><%= vendor.createdAt?.toLocaleDateString?.() || "" %></td></tr>
    </table>
  </div>
</div>

<%- include("../partials/layout-end") %>
<%- include("../../partials/footer") %>
