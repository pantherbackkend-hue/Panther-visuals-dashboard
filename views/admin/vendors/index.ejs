<%- include("../../partials/header", { pageTitle }) %>
<%- include("../partials/layout-start", { activeSection }) %>

<section class="admin-page-head">
  <div>
    <p class="eyebrow">Team</p>
    <h1>Editors</h1>
    <p class="muted">Manage editor accounts and workspace assignments.</p>
  </div>
  <div class="admin-actions">
    <a class="btn" href="/admin/editors/new">+ New Editor</a>
  </div>
</section>

<div class="card admin-panel">
  <div style="overflow-x:auto">
    <table class="table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Workspace</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% vendors.forEach(function(v) { %>
          <tr>
            <td><%= v.name %></td>
            <td><%= v.email %></td>
            <td><%= v.assignedShopName %></td>
            <td><span class="tag tag--<%= v.isActive === false ? 'danger' : 'ok' %>"><%= v.statusLabel %></span></td>
            <td>
              <div class="admin-actions">
                <a class="btn btn--small btn--outline" href="/admin/editors/<%= v._id %>">View</a>
                <a class="btn btn--small btn--outline" href="/admin/editors/<%= v._id %>/edit">Edit</a>
                <form method="post" action="/admin/editors/<%= v._id %>/toggle" class="inline" onsubmit="return confirm('Toggle this editor?')">
                  <button class="btn btn--small btn--ghost" type="submit"><%= v.isActive ? "Disable" : "Enable" %></button>
                </form>
                <form method="post" action="/admin/editors/<%= v._id %>/delete" class="inline" onsubmit="return confirm('Delete this editor?')">
                  <button class="btn btn--small btn--danger" type="submit">Delete</button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
        <% if (vendors.length === 0) { %>
          <tr><td colspan="5" class="muted">No editors found.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<%- include("../partials/layout-end") %>
<%- include("../../partials/footer") %>
