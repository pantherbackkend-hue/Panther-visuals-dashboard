<%- include("../partials/header", { pageTitle }) %>
<%- include("./partials/layout-start", { activeSection }) %>

<section class="admin-page-head">
  <div>
    <p class="eyebrow">Operations Center</p>
    <h1>Workspace</h1>
  </div>
  <div class="admin-actions">
    <a class="btn" href="/admin/projects/new">+ New Project</a>
  </div>
</section>

<div class="editor-tabs" role="tablist" aria-label="Project tabs">
  <button type="button" class="editor-tab<%= currentTab === 'my' ? ' is-active' : '' %>" data-tab="my" role="tab" aria-selected="<%= currentTab === 'my' ? 'true' : 'false' %>" aria-controls="tab-panel-my">My Projects <span class="editor-tab-count"><%= myProjects.length %></span></button>
  <button type="button" class="editor-tab<%= currentTab === 'ongoing' ? ' is-active' : '' %>" data-tab="ongoing" role="tab" aria-selected="<%= currentTab === 'ongoing' ? 'true' : 'false' %>" aria-controls="tab-panel-ongoing">Ongoing <span class="editor-tab-count"><%= ongoing.length %></span></button>
  <button type="button" class="editor-tab<%= currentTab === 'completed' ? ' is-active' : '' %>" data-tab="completed" role="tab" aria-selected="<%= currentTab === 'completed' ? 'true' : 'false' %>" aria-controls="tab-panel-completed">Completed <span class="editor-tab-count"><%= completed.length %></span></button>
</div>

<div class="card admin-panel admin-toolbar">
  <div class="admin-filter-bar">
    <label style="flex:1;min-width:180px">
      <span class="sr-only">Search</span>
      <input id="searchInput" type="search" placeholder="Search by name, client, editor..." oninput="applyFilters()" />
    </label>
    <label>
      <span class="sr-only">Priority</span>
      <select id="priorityFilter" onchange="applyFilters()">
        <option value="all">All Priorities</option>
        <option value="urgent">Urgent</option>
        <option value="high">High</option>
        <option value="medium">Medium</option>
        <option value="low">Low</option>
      </select>
    </label>
    <label>
      <span class="sr-only">Editor</span>
      <select id="editorFilter" onchange="applyFilters()">
        <option value="all">All Editors</option>
        <% editors.forEach(function(e) { %>
          <option value="<%= e._id %>"><%= e.name %></option>
        <% }) %>
        <option value="unassigned">Unassigned</option>
      </select>
    </label>
    <label>
      <span class="sr-only">Sort</span>
      <select id="sortFilter" onchange="applyFilters()">
        <option value="newest">Newest First</option>
        <option value="oldest">Oldest First</option>
        <option value="due_asc">Due Date (Earliest)</option>
        <option value="due_desc">Due Date (Latest)</option>
      </select>
    </label>
  </div>
</div>

<div class="editor-tab-content<%= currentTab === 'my' ? ' is-active' : '' %>" data-tab-panel="my" id="tab-panel-my" role="tabpanel" aria-label="My Projects">
  <% if (myProjects.length === 0) { %>
    <div class="card admin-panel"><p class="muted">No pending projects.</p></div>
  <% } else { %>
    <div class="editor-cards">
      <% myProjects.forEach(function(p) { %>
        <article class="card project-card" data-status="<%= p.status %>" data-priority="<%= p.priority %>" data-editor="<%= p.assignedEditor?._id || 'unassigned' %>" data-created="<%= new Date(p.createdAt).toISOString() %>" data-due="<%= p.dueDate ? new Date(p.dueDate).toISOString() : '' %>" data-search="<%= (p.projectName + ' ' + (p.clientName || '') + ' ' + (p.assignedEditor?.name || '')).toLowerCase() %>">
          <div class="project-card__head">
            <h3 class="project-card__name"><a href="/admin/projects/<%= p._id %>"><%= p.projectName %></a></h3>
            <span class="tag tag--<%= p.badgeColor %>"><%= p.statusLabel %></span>
          </div>
          <div class="project-card__meta">
            <span><strong>Client:</strong> <%= p.clientName %></span>
            <% if (p.clientRef?.channelName) { %><span><strong>Channel:</strong> <%= p.clientRef.channelName %></span><% } %>
            <span><strong>Editor:</strong> <% if (p.assignedEditor?.name) { %><%= p.assignedEditor.name %><% } else { %><span style="color:var(--warning)">Unassigned</span><% } %></span>
            <span><span class="priority-dot priority-dot--<%= p.priority %>"></span> <span class="capitalize"><%= p.priority %></span></span>
            <span><strong>Received:</strong> <%= p.receivedDate ? new Date(p.receivedDate).toLocaleDateString("en-IN") : new Date(p.createdAt).toLocaleDateString("en-IN") %></span>
            <span><strong>Due:</strong> <%= p.dueDate ? new Date(p.dueDate).toLocaleDateString("en-IN") : "—" %></span>
            <span><strong>Updated:</strong> <%= new Date(p.updatedAt).toLocaleDateString("en-IN") %></span>
            <% if (p.ownerAssignmentLabel) { %>
              <span class="tag tag--info" style="font-size:10px"><%= p.ownerAssignmentLabel %></span>
            <% } %>
          </div>
          <div class="project-card__actions">
            <a class="quick-action-btn" href="/admin/projects/<%= p._id %>">Open Project</a>
            <% if (p.ownerAssignment === "admin" || currentUser.role === "owner") { %>
              <a class="quick-action-btn" href="/admin/projects/<%= p._id %>/edit">Edit</a>
            <% } %>
            <% if (p.status === "pending_assignment") { %>
              <form class="inline-assign-form" style="display:inline-flex;gap:8px">
                <input type="hidden" name="projectId" value="<%= p._id %>" />
                <select name="editorId" required class="text-sm" style="padding:6px 8px;border:1px solid var(--border);border-radius:var(--radius-sm);background:var(--card)">
                  <option value="">Assign Editor</option>
                  <% editors.forEach(function(e) { %>
                    <option value="<%= e._id %>" <%= e.availability === 'on_leave' ? 'disabled' : '' %> data-availability="<%= e.availability %>" data-active="<%= e.activeCount %>">
                      <%= e.name %> — <%= e.specialization || "—" %> (<%= e.availability %>, <%= e.activeCount %> active)
                    </option>
                  <% }) %>
                </select>
                <button type="submit" class="btn btn--small">Assign</button>
              </form>
              <form method="post" action="/admin/projects/<%= p._id %>/delete" style="display:inline">
                <button type="button" class="quick-action-btn btn-delete" data-id="<%= p._id %>" style="color:var(--danger);border-color:var(--danger)">Delete</button>
              </form>
            <% } %>
            <% if (p.status === "assigned") { %>
              <form method="post" action="/admin/projects/<%= p._id %>/transition" class="inline">
                <input type="hidden" name="toStatus" value="ongoing" />
                <input type="hidden" name="notes" value="" />
                <button class="quick-action-btn" type="submit">Continue Workflow</button>
              </form>
            <% } %>
          </div>
        </article>
      <% }) %>
    </div>
  <% } %>
</div>

<div class="editor-tab-content<%= currentTab === 'ongoing' ? ' is-active' : '' %>" data-tab-panel="ongoing" id="tab-panel-ongoing" role="tabpanel" aria-label="Ongoing">
  <% if (ongoing.length === 0) { %>
    <div class="card admin-panel"><p class="muted">No ongoing projects.</p></div>
  <% } else { %>
    <div class="editor-cards">
      <% ongoing.forEach(function(p) { %>
        <article class="card project-card" data-status="<%= p.status %>" data-priority="<%= p.priority %>" data-editor="<%= p.assignedEditor?._id || 'unassigned' %>" data-created="<%= new Date(p.createdAt).toISOString() %>" data-due="<%= p.dueDate ? new Date(p.dueDate).toISOString() : '' %>" data-search="<%= (p.projectName + ' ' + (p.clientName || '') + ' ' + (p.assignedEditor?.name || '')).toLowerCase() %>">
          <div class="project-card__head">
            <h3 class="project-card__name"><a href="/admin/projects/<%= p._id %>"><%= p.projectName %></a></h3>
            <span class="tag tag--<%= p.badgeColor %>"><%= p.statusLabel %></span>
          </div>
          <div class="project-card__meta">
            <span><strong>Client:</strong> <%= p.clientName %></span>
            <% if (p.clientRef?.channelName) { %><span><strong>Channel:</strong> <%= p.clientRef.channelName %></span><% } %>
            <span><strong>Editor:</strong> <%= p.assignedEditor?.name || "Unassigned" %></span>
            <span><span class="priority-dot priority-dot--<%= p.priority %>"></span> <span class="capitalize"><%= p.priority %></span></span>
            <span><strong>Received:</strong> <%= p.receivedDate ? new Date(p.receivedDate).toLocaleDateString("en-IN") : new Date(p.createdAt).toLocaleDateString("en-IN") %></span>
            <span><strong>Due:</strong> <%= p.dueDate ? new Date(p.dueDate).toLocaleDateString("en-IN") : "—" %></span>
            <span><strong>Updated:</strong> <%= new Date(p.updatedAt).toLocaleDateString("en-IN") %></span>
          </div>
          <div class="project-card__actions">
            <a class="quick-action-btn" href="/admin/projects/<%= p._id %>">Open Project</a>
            <% if (p.status === "ongoing") { %>
              <form method="post" action="/admin/projects/<%= p._id %>/transition" class="inline">
                <input type="hidden" name="toStatus" value="submitted" />
                <input type="hidden" name="notes" value="" />
                <button class="quick-action-btn" type="submit">Continue Workflow</button>
              </form>
            <% } %>
            <% if (p.status === "submitted") { %>
              <button class="quick-action-btn btn-complete" data-id="<%= p._id %>">Complete</button>
              <form method="post" action="/admin/projects/<%= p._id %>/transition" class="inline">
                <input type="hidden" name="toStatus" value="ongoing" />
                <input type="hidden" name="notes" value="" />
                <button class="quick-action-btn" type="submit">Request Revision</button>
              </form>
            <% } %>
          </div>
        </article>
      <% }) %>
    </div>
  <% } %>
</div>

<div class="editor-tab-content<%= currentTab === 'completed' ? ' is-active' : '' %>" data-tab-panel="completed" id="tab-panel-completed" role="tabpanel" aria-label="Completed">
  <% if (completed.length === 0) { %>
    <div class="card admin-panel"><p class="muted">No completed projects.</p></div>
  <% } else { %>
    <div class="editor-cards">
      <% completed.forEach(function(p) { %>
        <article class="card project-card" data-status="<%= p.status %>" data-priority="<%= p.priority %>" data-editor="<%= p.assignedEditor?._id || 'unassigned' %>" data-created="<%= new Date(p.createdAt).toISOString() %>" data-due="<%= p.dueDate ? new Date(p.dueDate).toISOString() : '' %>" data-search="<%= (p.projectName + ' ' + (p.clientName || '') + ' ' + (p.assignedEditor?.name || '')).toLowerCase() %>">
          <div class="project-card__head">
            <h3 class="project-card__name"><a href="/admin/projects/<%= p._id %>"><%= p.projectName %></a></h3>
            <span class="tag tag--<%= p.badgeColor %>"><%= p.statusLabel %></span>
          </div>
          <div class="project-card__meta">
            <span><strong>Client:</strong> <%= p.clientName %></span>
            <% if (p.clientRef?.channelName) { %><span><strong>Channel:</strong> <%= p.clientRef.channelName %></span><% } %>
            <span><strong>Editor:</strong> <%= p.assignedEditor?.name || "Unassigned" %></span>
            <span><span class="priority-dot priority-dot--<%= p.priority %>"></span> <span class="capitalize"><%= p.priority %></span></span>
            <span><strong>Received:</strong> <%= p.receivedDate ? new Date(p.receivedDate).toLocaleDateString("en-IN") : new Date(p.createdAt).toLocaleDateString("en-IN") %></span>
            <span><strong>Due:</strong> <%= p.dueDate ? new Date(p.dueDate).toLocaleDateString("en-IN") : "—" %></span>
            <span><strong>Updated:</strong> <%= new Date(p.updatedAt).toLocaleDateString("en-IN") %></span>
            <span><strong>Amount:</strong> <%= formatMoney(p.payment?.editorAmount || 0) %></span>
          </div>
          <div class="project-card__actions">
            <a class="quick-action-btn" href="/admin/projects/<%= p._id %>">Open Project</a>
            <% if (p.payment?.status === "paid") { %>
              <span class="tag tag--ok">Paid</span>
            <% } else { %>
              <span class="tag tag--pending">Awaiting Payment</span>
              <button class="quick-action-btn btn-payment" data-id="<%= p._id %>" style="border-color:var(--success);color:var(--success)">Mark Paid</button>
            <% } %>
          </div>
        </article>
      <% }) %>
    </div>
  <% } %>
</div>

<div id="confirm-dialog" class="confirm-overlay" role="dialog" aria-modal="true" aria-labelledby="confirm-title">
  <div class="confirm-dialog">
    <p id="confirm-title"></p>
    <div class="confirm-dialog__actions">
      <button class="btn btn--outline" id="confirm-cancel">Cancel</button>
      <button class="btn" id="confirm-ok">Confirm</button>
    </div>
  </div>
</div>

<script>
var confirmDialog = document.getElementById("confirm-dialog");
var confirmTitle = document.getElementById("confirm-title");
var confirmOk = document.getElementById("confirm-ok");
var confirmCancel = document.getElementById("confirm-cancel");
var pendingConfirm = null;

function showConfirm(msg) {
  return new Promise(function (resolve) {
    confirmTitle.textContent = msg;
    confirmDialog.classList.add("is-visible");
    pendingConfirm = resolve;
  });
}

confirmOk.addEventListener("click", function () {
  confirmDialog.classList.remove("is-visible");
  if (pendingConfirm) pendingConfirm(true);
  pendingConfirm = null;
});

confirmCancel.addEventListener("click", function () {
  confirmDialog.classList.remove("is-visible");
  if (pendingConfirm) pendingConfirm(false);
  pendingConfirm = null;
});

confirmDialog.addEventListener("click", function (e) {
  if (e.target === confirmDialog) {
    confirmDialog.classList.remove("is-visible");
    if (pendingConfirm) pendingConfirm(false);
    pendingConfirm = null;
  }
});

function showInlineError(el, msg) {
  var existing = el.parentNode.querySelector(".alert-inline");
  if (!existing) {
    existing = document.createElement("div");
    existing.className = "alert-inline alert-inline--error is-visible";
    el.parentNode.insertBefore(existing, el.nextSibling);
  } else {
    existing.classList.add("is-visible");
    existing.classList.remove("alert-inline--success");
    existing.classList.add("alert-inline--error");
  }
  existing.textContent = msg;
  setTimeout(function () { existing.classList.remove("is-visible"); }, 4000);
}

(function () {
  var tabs = document.querySelectorAll(".editor-tab");
  var panels = document.querySelectorAll(".editor-tab-content");

  tabs.forEach(function (tab) {
    tab.addEventListener("click", function () {
      var target = tab.getAttribute("data-tab");
      tabs.forEach(function (t) { t.classList.remove("is-active"); t.setAttribute("aria-selected", "false"); });
      panels.forEach(function (p) { p.classList.remove("is-active"); });
      tab.classList.add("is-active");
      tab.setAttribute("aria-selected", "true");
      var panel = document.querySelector('[data-tab-panel="' + target + '"]');
      if (panel) panel.classList.add("is-active");
      history.replaceState(null, "", "?tab=" + target);
    });
  });

  function applyFilters() {
    var search = document.getElementById('searchInput').value.toLowerCase().trim();
    var priority = document.getElementById('priorityFilter').value;
    var editor = document.getElementById('editorFilter').value;
    var sort = document.getElementById('sortFilter').value;
    var activePanel = document.querySelector('.editor-tab-content.is-active');
    if (!activePanel) return;

    var cards = activePanel.querySelectorAll('.project-card');
    var visible = [];

    cards.forEach(function(card) {
      var match = true;
      if (search && !card.dataset.search.includes(search)) match = false;
      if (priority !== 'all' && card.dataset.priority !== priority) match = false;
      if (editor !== 'all' && card.dataset.editor !== editor) match = false;
      card.style.display = match ? '' : 'none';
      if (match) visible.push(card);
    });

    if (visible.length > 1) {
      visible.sort(function(a, b) {
        if (sort === 'oldest') return new Date(a.dataset.created) - new Date(b.dataset.created);
        if (sort === 'due_asc') {
          if (!a.dataset.due) return 1;
          if (!b.dataset.due) return -1;
          return new Date(a.dataset.due) - new Date(b.dataset.due);
        }
        if (sort === 'due_desc') {
          if (!a.dataset.due) return 1;
          if (!b.dataset.due) return -1;
          return new Date(b.dataset.due) - new Date(a.dataset.due);
        }
        return new Date(b.dataset.created) - new Date(a.dataset.created);
      });
      var container = activePanel.querySelector('.editor-cards');
      visible.forEach(function(card) { container.appendChild(card); });
    }
  }

  window.applyFilters = applyFilters;

  document.querySelectorAll('.inline-assign-form').forEach(function(form) {
    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      var btn = this.querySelector('button[type="submit"]');
      var select = this.querySelector('select[name="editorId"]');
      var selected = select.options[select.selectedIndex];

      if (!select.value) { showInlineError(btn, 'Please select an editor.'); return; }
      if (selected.dataset.availability === 'on_leave') { showInlineError(btn, 'Cannot assign: Editor is on leave.'); return; }
      if (selected.dataset.availability === 'busy' && parseInt(selected.dataset.active) >= 3) {
        var confirmed = await showConfirm('Editor is fully occupied. Assign anyway?');
        if (!confirmed) return;
      }

      btn.disabled = true;
      btn.textContent = '...';

      try {
        var res = await fetch('/admin/workspace/assign', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ projectId: this.querySelector('input[name="projectId"]').value, editorId: select.value }),
        });
        var result = await res.json();
        if (result.success) { window.location.reload(); }
        else { showInlineError(btn, result.error || 'Assignment failed.'); }
      } catch (err) { showInlineError(btn, 'Network error.'); }
      finally { btn.disabled = false; btn.textContent = 'Assign'; }
    });
  });

  document.querySelectorAll('.btn-complete').forEach(function(btn) {
    btn.addEventListener('click', async function() {
      var id = btn.dataset.id;
      if (!id) return;
      btn.disabled = true;
      btn.textContent = '...';
      try {
        var res = await fetch('/admin/projects/' + id + '/complete', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
        });
        var result = await res.json();
        if (result.success) { window.location.reload(); }
        else { showInlineError(btn, result.error || 'Failed to complete.'); }
      } catch (err) { showInlineError(btn, 'Network error.'); }
      finally { btn.disabled = false; btn.textContent = 'Complete'; }
    });
  });

  document.querySelectorAll('.btn-payment').forEach(function(btn) {
    btn.addEventListener('click', async function() {
      var id = btn.dataset.id;
      if (!id) return;
      btn.disabled = true;
      btn.textContent = '...';
      try {
        var res = await fetch('/admin/projects/' + id + '/payment-done', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
        });
        var result = await res.json();
        if (result.success) { window.location.reload(); }
        else { showInlineError(btn, result.error || 'Failed to mark payment.'); }
      } catch (err) { showInlineError(btn, 'Network error.'); }
      finally { btn.disabled = false; btn.textContent = 'Mark Paid'; }
    });
  });

  document.querySelectorAll('.btn-delete').forEach(function(btn) {
    btn.addEventListener('click', async function() {
      var id = btn.dataset.id;
      if (!id) return;
      var confirmed = await showConfirm('Are you sure you want to delete this project? This action cannot be undone.');
      if (!confirmed) return;
      btn.disabled = true;
      btn.textContent = '...';
      try {
        var form = btn.closest('form');
        var res = await fetch(form.action, { method: 'POST', redirect: 'manual' });
        if (res.ok || res.type === 'opaqueredirect') { window.location.reload(); }
        else { showInlineError(btn, 'Failed to delete.'); }
      } catch (err) { showInlineError(btn, 'Network error.'); }
      finally { btn.disabled = false; btn.textContent = 'Delete'; }
    });
  });
})();
</script>

<%- include("./partials/layout-end") %>
<%- include("../partials/footer") %>