<%
// ── Shared Asset Table Partial ───────────────────────────────
// Parameters:
//   mode  : "vendor" (import preview with editable fields) | "student" (public listing)
//   items : array of item objects
//   stats : computed stats (vendor mode only, optional)
//   shop  : shop object (student mode only, optional)
//
// Items:
//   .name, .category, .price (number), .rowStatus (vendor), .isAvailable (student)
%>
<%
  var availCount = 0;
  if (mode === 'student') {
    availCount = items.filter(function(it) { return it.isAvailable; }).length;
  }
%>

<style>
.import-actions {
  position: sticky;
  top: 92px;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  padding: 10px 14px;
  margin-bottom: 12px;
  background: rgba(255,255,255,0.96);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  box-shadow: 0 4px 16px rgba(31,31,31,0.06);
  backdrop-filter: blur(8px);
}
.import-actions__left {
  display: flex;
  align-items: center;
  gap: 8px;
  flex: 1;
  min-width: 0;
}
.import-actions__right {
  display: flex;
  align-items: center;
  gap: 8px;
}
.import-search-wrap {
  position: relative;
  flex: 0 1 220px;
}
.import-search-wrap input {
  width: 100%;
  min-height: 36px;
  padding: 6px 10px 6px 30px;
  font-size: 13px;
}
.import-search-wrap::before {
  content: '\1F50D';
  position: absolute;
  left: 9px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 13px;
  opacity: 0.5;
  pointer-events: none;
}
.import-filters {
  display: flex;
  align-items: center;
  gap: 4px;
  margin-bottom: 10px;
  flex-wrap: wrap;
}
.filter-btn {
  min-height: 30px;
  padding: 4px 10px;
  border-radius: 999px;
  border: 1px solid var(--border);
  background: var(--card);
  color: var(--muted);
  font-size: 12px;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.12s;
  white-space: nowrap;
}
.filter-btn:hover { border-color: var(--primary); color: var(--text); }
.filter-btn.is-active { background: var(--primary); color: #fff; border-color: var(--primary); }
.filter-btn--count {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 18px;
  height: 18px;
  border-radius: 999px;
  background: rgba(0,0,0,0.08);
  font-size: 10px;
  font-weight: 800;
  padding: 0 5px;
  margin-left: 4px;
}
.filter-btn.is-active .filter-btn--count { background: rgba(255,255,255,0.25); }
.import-table-wrap {
  overflow-x: auto;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  background: var(--card);
}
.import-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 13px;
  min-width: 600px;
}
.import-table thead {
  position: sticky;
  top: 0;
  z-index: 2;
}
.import-table th {
  background: #f9f6f2;
  padding: 8px;
  font-size: 10px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--muted);
  border-bottom: 2px solid var(--border);
  white-space: nowrap;
  text-align: left;
  vertical-align: middle;
}
.import-table td {
  padding: 4px 8px;
  border-bottom: 1px solid #f0eeeb;
  vertical-align: middle;
  height: 44px;
}
.import-table tbody tr { transition: background 0.1s; }
.import-table tbody tr:hover { background: #fdf8f2; }
.import-table input[type="text"],
.import-table input[type="number"] {
  width: 100%;
  min-height: 30px;
  padding: 3px 6px;
  font-size: 12px;
  border: 1px solid transparent;
  background: transparent;
  border-radius: 4px;
  outline: none;
  transition: border-color 0.12s, background 0.12s;
  box-sizing: border-box;
}
.import-table .cell--center { text-align: center; }
.import-table .cell--right { text-align: right; }
.status-badge {
  display: inline-flex;
  align-items: center;
  min-height: 22px;
  padding: 2px 8px;
  border-radius: 999px;
  font-size: 10px;
  font-weight: 800;
  white-space: nowrap;
}
.status-badge--ready { background: #dcfce7; color: #166534; }
.status-badge--review { background: #fef9c3; color: #854d0e; }
.status-badge--duplicate { background: #fee2e2; color: #991b1b; }
.status-badge--noprice { background: #fee2e2; color: #991b1b; }
.status-badge--unavailable { background: #fee2e2; color: #991b1b; }
.status-badge--available { background: #dcfce7; color: #166534; }
.import-table .is-hidden { display: none; }
.row-actions { display: flex; gap: 2px; }
.row-actions button {
  min-height: 26px; width: 26px; padding: 0;
  border: 1px solid transparent; border-radius: 4px;
  background: none; color: #bbb; cursor: pointer; font-size: 14px;
  display: inline-flex; align-items: center; justify-content: center;
}
.row-actions button:hover { border-color: #eee; color: var(--muted); }
.row-actions .del-btn:hover { border-color: var(--danger-soft); color: var(--danger); background: var(--danger-soft); }
.import-table input[type="checkbox"] {
  width: 16px; height: 16px; margin: 0; cursor: pointer;
  accent-color: var(--primary);
}
.view-link {
  display: inline-flex;
  align-items: center;
  min-height: 26px;
  padding: 2px 10px;
  border-radius: 6px;
  font-size: 11px;
  font-weight: 700;
  color: var(--primary);
  text-decoration: none;
  transition: background 0.12s;
}
.view-link:hover { background: rgba(255,122,0,0.08); }
@media (max-width: 900px) {
  .import-actions { flex-wrap: wrap; }
  .import-actions__right { width: 100%; }
  .import-search-wrap { flex: 1; }
}
@media (max-width: 768px) {
  .import-actions {
    top: 56px;
    padding: 8px 12px;
    margin-bottom: 8px;
  }
  .import-actions__left { min-width: 0; }
  .import-search-wrap { flex: 1; }
  .import-search-wrap input {
    min-height: 40px;
    font-size: 14px;
    padding: 8px 10px 8px 30px;
  }
  .import-filters {
    flex-wrap: nowrap;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
    gap: 4px;
    margin-bottom: 8px;
    padding-bottom: 4px;
  }
  .import-filters::-webkit-scrollbar { display: none; }
  .filter-btn {
    min-height: 32px;
    padding: 4px 12px;
    font-size: 12px;
    flex-shrink: 0;
  }
  .import-table-wrap {
    overflow-x: visible;
    border: none;
    background: transparent;
  }
  .import-table { min-width: 0; }
  .import-table thead { display: none; }
  .import-table tbody tr {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px 10px;
    padding: 10px 12px;
    margin-bottom: 10px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--card);
    height: auto;
  }
  .import-table tbody tr:hover { background: var(--card); }
  .import-table tbody tr td {
    border: none;
    padding: 0;
    height: auto;
    vertical-align: middle;
  }
}
@media (max-width: 480px) {
  .import-actions { top: 48px; }
  .import-table tbody tr {
    padding: 8px 10px;
    gap: 4px 8px;
    margin-bottom: 8px;
  }
}
</style>

<% if (mode === 'vendor') { %>
<!-- ── STICKY ACTION BAR (vendor) ── -->
<div class="import-actions" id="action-bar">
  <div class="import-actions__left">
    <button class="btn btn--small" type="submit" id="import-btn" style="min-height:36px;font-size:13px;">
      Import <span id="import-count"><%= typeof stats !== 'undefined' ? stats.ready : 0 %></span> Assets
    </button>
    <button class="btn btn--small btn--outline" type="button" id="review-btn" style="min-height:36px;font-size:13px;">
      Review Issues (<%= typeof stats !== 'undefined' ? (stats.noprice + stats.duplicate) : 0 %>)
    </button>
    <button type="button" class="btn btn--small btn--ghost" id="discard-btn" style="min-height:36px;font-size:13px;">
      Discard
    </button>
    <span style="width:1px;height:22px;background:var(--border);margin:0 4px;"></span>
  </div>
  <div class="import-actions__right">
    <div class="import-search-wrap">
      <input type="text" id="import-search" placeholder="Search items..." autocomplete="off" />
    </div>
  </div>
</div>
<% } else { %>
<!-- ── SEARCH BAR (student) ── -->
<div class="import-actions" id="action-bar">
  <div class="import-actions__left"></div>
  <div class="import-actions__right">
    <div class="import-search-wrap">
      <input type="text" id="import-search" placeholder="Search assets..." autocomplete="off" />
    </div>
  </div>
</div>
<% } %>

<!-- ── FILTER TABS ── -->
<div class="import-filters" id="filter-bar">
  <button type="button" class="filter-btn is-active" data-filter="all">
    All <span class="filter-btn--count"><%= items.length %></span>
  </button>
  <% if (mode === 'student') { %>
  <button type="button" class="filter-btn" data-filter="available">
    Available <span class="filter-btn--count"><%= availCount %></span>
  </button>
  <button type="button" class="filter-btn" data-filter="unavailable">
    Unavailable <span class="filter-btn--count"><%= items.length - availCount %></span>
  </button>
  <% } else { %>
  <button type="button" class="filter-btn" data-filter="ready">
    Ready <span class="filter-btn--count"><%= typeof stats !== 'undefined' ? stats.ready : 0 %></span>
  </button>
  <% } %>
</div>

<!-- ── TABLE ── -->
<div class="import-table-wrap">
<table class="import-table" id="import-table">
  <thead>
    <tr>
      <% if (mode === 'vendor') { %>
      <th style="width:30px;"><input type="checkbox" id="select-all" /></th>
      <% } %>
      <th style="width:32px;">#</th>
      <th style="min-width:140px;">Asset Name</th>
      <th style="width:100px;">Category</th>
      <th style="width:100px;">Price</th>
      <th style="width:90px;"><%= mode === 'student' ? 'Availability' : 'Status' %></th>
      <th style="width:40px;"></th>
    </tr>
  </thead>
  <tbody>
    <% items.forEach(function(item, i) { %>
    <tr
      data-index="<%= i %>"
      data-name="<%= (item.name||'').toLowerCase() %>"
      data-category="<%= (item.category||'').toLowerCase() %>"
      <% if (mode === 'vendor') { %>
      data-status="<%= item.rowStatus %>"
      <% } else { %>
      data-available="<%= item.isAvailable ? 'true' : 'false' %>"
      <% } %>
    >
      <% if (mode === 'vendor') { %>
      <td class="cell--center"><input type="checkbox" class="row-select" data-index="<%= i %>" /></td>
      <% } %>
      <td class="cell--center" style="color:var(--muted);font-size:11px;"><%= i+1 %></td>
      <td>
        <% if (mode === 'vendor') { %>
        <input name="items[<%= i %>][name]" type="text" value="<%= item.name %>" required />
        <% } else { %>
        <%= item.name %>
        <% } %>
      </td>
      <td>
        <% if (mode === 'vendor') { %>
        <input name="items[<%= i %>][category]" type="text" value="<%= item.category || '' %>" placeholder="Uncategorized" />
        <% } else { %>
        <%= item.category || 'Uncategorized' %>
        <% } %>
      </td>
      <td>
        <% if (mode === 'vendor') { %>
        <input name="items[<%= i %>][price]" type="number" step="0.01" min="0" value="<%= Number(item.price || 0).toFixed(2) %>" required />
        <% } else { %>
        $<%= Number(item.price || 0).toFixed(2) %>
        <% } %>
      </td>
      <td>
        <% if (mode === 'vendor') { %>
        <span class="status-badge status-badge--<%= item.rowStatus %>">
          <% var statusLabels = { ready:'Ready', review:'Needs Review', duplicate:'Duplicate', noprice:'No Price' }; %>
          <%= statusLabels[item.rowStatus] || item.rowStatus %>
        </span>
        <% } else { %>
        <span class="status-badge status-badge--<%= item.isAvailable ? 'available' : 'unavailable' %>">
          <%= item.isAvailable ? 'Available' : 'Unavailable' %>
        </span>
        <% } %>
      </td>
      <td>
        <% if (mode === 'vendor') { %>
        <div class="row-actions">
          <button type="button" class="del-btn" data-index="<%= i %>" title="Delete item">&times;</button>
        </div>
        <% } else { %>
        <a class="view-link" href="/shops/<%= shop ? shop._id : '' %>/assets/<%= item._id || i %>">View</a>
        <% } %>
      </td>
    </tr>
    <% }) %>
    <% if (items.length === 0) { %>
    <tr>
      <td colspan="<%= mode === 'vendor' ? 7 : 6 %>" style="text-align:center;padding:32px 24px;color:var(--muted);">
        No assets found.
      </td>
    </tr>
    <% } %>
  </tbody>
</table>
</div>

<script src="/js/menu-table.js"></script>
