<%- include("../partials/header", { pageTitle }) %>

<section class="admin-page-head">
  <div>
    <p class="eyebrow">Reference library</p>
    <h1>My Assets</h1>
    <p class="muted">Reference assets for clients you have projects for. Managed by admin.</p>
  </div>
</section>

<% if (!clientAssets || clientAssets.length === 0) { %>
  <div class="card admin-panel"><p class="muted">No assets available. Reference assets appear here when clients have assets added by the admin.</p></div>
<% } else { %>
  <% var hasAnyAssets = false; %>
  <% clientAssets.forEach(function(item) { %>
    <% var client = item.client; %>
    <% if (!client.assets || client.assets.length === 0) return; %>
    <% hasAnyAssets = true; %>
    <div class="card admin-panel" style="margin-bottom:16px">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
        <div>
          <h2 class="h2 mt-0 mb-0"><%= client.name %></h2>
          <% if (client.channelName) { %><p class="muted mt-0 mb-0 text-sm"><%= client.channelName %></p><% } %>
        </div>
        <div class="flex gap-4 flex-wrap">
          <% item.statuses.forEach(function(s) { %>
            <span class="tag tag--<%= getBadgeColor(s) %> text-xs"><%= formatStatus(s) %></span>
          <% }) %>
        </div>
      </div>
      <div class="editor-cards">
        <% client.assets.forEach(function(asset) { %>
          <article class="card project-card">
            <div class="project-card__head">
              <h3 class="project-card__name"><%= asset.label || "Asset" %></h3>
              <% if (asset.isDefault) { %><span class="tag tag--ok" style="font-size:10px">Default</span><% } %>
            </div>
            <% if (asset.description) { %>
              <p class="muted text-sm mt-0 mb-0"><%= asset.description %></p>
            <% } %>
            <div class="asset-link-row" style="margin-top:8px">
              <a href="<%= asset.driveLink %>" target="_blank" rel="noopener" class="asset-link"><%= asset.driveLink.length > 60 ? asset.driveLink.slice(0, 60) + "..." : asset.driveLink %></a>
              <button class="quick-action-btn btn-copy-asset" data-link="<%= asset.driveLink %>">Copy</button>
            </div>
          </article>
        <% }) %>
      </div>
    </div>
  <% }); %>
  <% if (!hasAnyAssets) { %>
    <div class="card admin-panel"><p class="muted">Your assigned clients do not have any reference assets yet.</p></div>
  <% } %>
<% } %>

<script>
  (function () {
    var copyBtns = document.querySelectorAll(".btn-copy-asset");
    copyBtns.forEach(function (btn) {
      btn.addEventListener("click", function () {
        var link = btn.getAttribute("data-link");
        if (!link) return;
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(link).then(function () {
            btn.textContent = "Copied!";
            setTimeout(function () { btn.textContent = "Copy"; }, 2000);
          });
        } else {
          var ta = document.createElement("textarea");
          ta.value = link;
          ta.style.position = "fixed";
          ta.style.opacity = "0";
          document.body.appendChild(ta);
          ta.select();
          try { document.execCommand("copy"); btn.textContent = "Copied!"; setTimeout(function () { btn.textContent = "Copy"; }, 2000); } catch (e) {}
          document.body.removeChild(ta);
        }
      });
    });
  })();
</script>

<%- include("../partials/footer") %>