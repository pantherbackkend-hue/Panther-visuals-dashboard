<%- include("../partials/header", { pageTitle }) %>

<section class="hero hero--compact">
  <h1>My projects</h1>
</section>

<% if (!orders.length) { %>
  <div class="card"><p class="muted">No projects yet.</p></div>
<% } else { %>
  <ul class="order-list">
    <% orders.forEach((o) => { %>
      <% const isAdjusted = !!(o.adjustedAt); %>
      <% const label = o.status === "completed" ? "Completed" : o.status === "cancelled" ? "Cancelled" : isAdjusted ? "Project Updated" : o.status === "pending_payment" ? "Payment Pending" : o.status === "paid" ? "Pending - awaiting editor" : o.status === "accepted" ? "Assigned" : o.status === "in_progress" ? "In Progress" : o.status === "in_review" ? "In Review" : o.status === "revision" ? "Revision" : o.status; %>
      <% const tagClass = o.status === "completed" ? "ok" : o.status === "cancelled" ? "warn" : isAdjusted ? "warn" : o.status === "in_progress" || o.status === "in_review" || o.status === "revision" || o.status === "accepted" || o.status === "paid" ? "pending" : "muted"; %>
      <li class="card order-list__item">
        <div class="order-list__meta">
          <a href="/projects/<%= o._id %>">Project …<%= String(o._id).slice(-6) %></a>
          <span class="tag tag--<%= tagClass %>"><%= label %></span>
        </div>
        <p class="muted small"><%= o.shop?.name || "Workspace" %> · ₹<%= (o.updatedTotal || o.total).toFixed(2) %> · <%= new Date(o.createdAt).toLocaleString("en-IN", {
  timeZone: "Asia/Kolkata"
}) %></p>
        <% if (isAdjusted) { %>
          <p class="muted small">Refund: ₹<%= (o.refundAmount || 0).toFixed(2) %></p>
        <% } %>
      </li>
    <% }) %>
  </ul>
<% } %>

<%- include("../partials/footer") %>
