<%- include("../partials/header", { pageTitle }) %>

<section class="hero hero--compact">
  <h1>Completed and cancelled projects</h1>
  <p class="muted">Projects that were completed or cancelled.</p>
</section>

<% if (!orders.length) { %>
  <div class="card empty-state">
    <p class="muted">No completed or cancelled projects yet.</p>
  </div>
<% } else { %>
  <div class="vendor-order-grid">
    <% orders.forEach((order) => { %>
      <article class="card vendor-order-card">
        <a class="vendor-order-card__overlay" href="/editor/orders/<%= order._id %>" aria-label="View project #<%= String(order._id).slice(-6).toUpperCase() %> details"></a>
        <div class="vendor-order-card__head">
          <div>
            <p class="eyebrow"><%= new Date(order.createdAt).toLocaleString("en-IN", {
  timeZone: "Asia/Kolkata"
}) %></p>
            <h2>#<%= String(order._id).slice(-6).toUpperCase() %></h2>
          </div>
          <div class="vendor-order-card__status">
            <% const statusLabel = order.status === "completed" ? "Completed" : order.status === "cancelled" ? "Cancelled" : order.status; %>
            <% const statusClass = order.status === "completed" ? "ok" : order.status === "cancelled" ? "warn" : "muted"; %>
            <span class="tag tag--<%= statusClass %>"><%= statusLabel %></span>
          </div>
        </div>
        <ul class="vendor-order-card__items">
          <% order.items.forEach((item) => { %>
            <li>
              <span><%= item.name %>
                <% if (item.variantName) { %>
                  <span class="muted small">(<%= item.variantName %>)</span>
                <% } %>
              </span>
              <strong><%= item.quantity %> x</strong>
            </li>
          <% }) %>
        </ul>
        <p class="cart-total"><strong>Total:</strong> &#8377;<%= Number(order.total).toFixed(2) %></p>
      </article>
    <% }) %>
  </div>
<% } %>

<%- include("../partials/footer") %>
