<%- include("../partials/header", { pageTitle }) %>

<% const orderNumber = `#${String(order._id).slice(-6).toUpperCase()}`; %>
<% const statusLabels = {
  pending_payment: "Payment Pending",
  paid: "Paid",
  accepted: "Assigned",
  in_progress: "In Progress",
  in_review: "In Review",
  revision: "Revision",
  completed: "Completed",
  cancelled: "Cancelled",
}; %>
<% const refundLabels = {
  none: "No refund",
  pending: "Refund Pending",
  completed: "Refund Completed",
  failed: "Refund Failed",
}; %>
<% const isAdjusted = !!(order.adjustedAt); %>
<% const paymentStatus = order.status === "pending_payment"
  ? "Payment Pending"
  : order.status === "cancelled" && order.refundStatus === "completed"
    ? "Refunded"
    : "Payment Confirmed"; %>
<% const timelineStage = order.status === "completed"
  ? 6
  : order.status === "in_review" || order.status === "revision"
    ? 5
    : order.status === "in_progress"
      ? 4
      : order.status === "accepted"
        ? 3
        : order.status === "paid"
          ? 2
          : 1; %>
<% const timeline = [
  ["Project Created", 1],
  ["Paid", 2],
  ["Assigned to Editor", 3],
  ["In Progress", 4],
  ["Sent for Review", 5],
  ["Completed", 6],
]; %>

<div class="breadcrumb">
  <a href="<%= backHref %>">Back</a>
  <span class="muted"> / </span>
  <span>Project <%= orderNumber %></span>
</div>

<div class="vendor-detail-actions">
  <a class="btn btn--outline" href="<%= backHref %>">Back</a>
</div>

<section class="card vendor-order-detail">
  <div class="order-detail__head">
    <div>
      <p class="eyebrow">Project Number</p>
      <h1><%= orderNumber %></h1>
    </div>
    <span class="tag tag--<%= order.status === "completed" ? "ok" : order.status === "cancelled" ? "warn" : "pending" %>">
      <%= statusLabels[order.status] || "In Progress" %>
    </span>
  </div>

  <div class="vendor-detail-grid">
    <div>
      <span>Client Name</span>
      <strong><%= order.customer?.name || "Client" %></strong>
    </div>
    <div>
      <span>Workspace</span>
      <strong><%= order.shop?.name || "Workspace" %></strong>
    </div>
    <div>
      <span>Project Status</span>
      <strong><%= statusLabels[order.status] || "In Progress" %></strong>
    </div>
    <div>
      <span>Total Amount</span>
      <strong>&#8377;<%= Number(order.total).toFixed(2) %></strong>
    </div>
    <div>
      <span>Payment Status</span>
      <strong><%= paymentStatus %></strong>
    </div>
    <div>
      <span>Transaction ID</span>
      <strong class="mono"><%= order.paymentNote || "Not recorded" %></strong>
    </div>
    <div>
      <span>Refund Status</span>
      <strong><%= refundLabels[order.refundStatus] || "No refund" %></strong>
    </div>
    <% if (isAdjusted) { %>
      <div>
        <span>Original Total</span>
        <strong>&#8377;<%= Number(order.originalTotal).toFixed(2) %></strong>
      </div>
      <div>
        <span>Adjusted Total</span>
        <strong>&#8377;<%= Number(order.updatedTotal || order.total).toFixed(2) %></strong>
      </div>
      <div>
        <span>Refund Amount</span>
        <strong>&#8377;<%= Number(order.refundAmount || 0).toFixed(2) %></strong>
      </div>
      <div>
        <span>Adjustment Reason</span>
        <strong><%= order.adjustmentReason || "N/A" %></strong>
      </div>
    <% } %>
    <div>
      <span>Project Created</span>
      <strong><%= formatLocalDateTime(order.createdAt) %></strong>
    </div>
    <% if (order.collectedAt) { %>
    <div>
      <span>Completed At</span>
      <strong><%= formatLocalDateTime(order.collectedAt) %></strong>
    </div>
    <% } %>
  </div>

  <h2 class="h2">Items</h2>
  <ul class="vendor-detail-items">
    <% order.items.forEach((item) => { %>
      <li class="<%= item.status === 'removed' ? 'item-removed' : '' %>">
        <span><%= item.name %>
          <% if (item.variantName) { %><span class="muted small">(<%= item.variantName %>)</span><% } %>
        </span>
        <strong>&times;<%= item.quantity %></strong>
        <% if (item.status === "removed") { %><span class="muted small"> (removed)</span><% } %>
      </li>
    <% }) %>
  </ul>

  <h2 class="h2">Project Timeline</h2>
  <ol class="vendor-timeline" aria-label="Project timeline">
    <% timeline.forEach(([label, index]) => { %>
      <li class="vendor-timeline__step <%= timelineStage >= index ? "is-complete" : "" %> <%= timelineStage === index && order.status !== "completed" ? "is-current" : "" %>">
        <span class="vendor-timeline__dot"><% if (timelineStage >= index) { %>&#10003;<% } else { %><%= index %><% } %></span>
        <span><%= label %></span>
      </li>
    <% }) %>
  </ol>

  <div class="vendor-order-card__actions">
    <% if (order.status === "paid") { %>
      <form method="post" action="/editor/orders/<%= order._id %>/accept">
        <button class="btn btn--wide" type="submit">Accept Project</button>
      </form>
      <form method="post" action="/editor/orders/<%= order._id %>/cancel" onsubmit="return confirm('Cancel this project and refund client?');">
        <button class="btn btn--danger btn--wide" type="submit">Cancel</button>
      </form>
    <% } else if (order.status === "accepted") { %>
      <form method="post" action="/editor/orders/<%= order._id %>/start">
        <button class="btn btn--wide" type="submit">Start Working</button>
      </form>
    <% } else if (order.status === "in_progress") { %>
      <form method="post" action="/editor/orders/<%= order._id %>/review">
        <button class="btn btn--wide" type="submit">Send for Review</button>
      </form>
    <% } else if (order.status === "in_review" || order.status === "revision") { %>
      <form method="post" action="/editor/orders/<%= order._id %>/complete">
        <button class="btn btn--wide" type="submit">Complete Project</button>
      </form>
    <% } %>
  </div>
</section>

<%- include("../partials/footer") %>
