<%- include("../partials/header", { pageTitle }) %>

<section class="hero hero--compact">
  <h1>Payment Settings</h1>
  <p class="muted"><%= shop.name %></p>
</section>

<div class="card admin-panel">
  <form method="post" action="/editor/payment/settings" class="form">

    <label>
      <span>Payment Gateway</span>
      <select name="paymentGateway" id="paymentGatewaySelect">
        <option value="razorpay" <%= shop.paymentGateway === "razorpay" ? "selected" : "" %>>Razorpay</option>
        <option value="easebuzz" <%= shop.paymentGateway === "easebuzz" ? "selected" : "" %>>Easebuzz</option>
        <option value="phonepe" <%= shop.paymentGateway === "phonepe" ? "selected" : "" %>>PhonePe</option>
        <option value="paytm" disabled>Paytm (coming soon)</option>
        <option value="bharatpe" disabled>BharatPe (coming soon)</option>
      </select>
    </label>

    <fieldset class="fieldset" data-gateway="razorpay">
      <legend>Razorpay Credentials</legend>

      <% if (shop.paymentConfigured) { %>
        <div class="flash flash--success">Razorpay is configured and active for this workspace.</div>
      <% } else { %>
        <div class="flash flash--info">Enter your Razorpay API keys to accept live payments.</div>
      <% } %>

      <label>
        <span>Key ID</span>
        <input name="razorpayKeyId" type="text" maxlength="100"
          value="<%= shop.paymentSettings?.razorpay?.keyId || "" %>"
          placeholder="rzp_live_... or rzp_test_..." />
      </label>

      <label>
        <span>Key Secret</span>
        <div class="pw-field">
          <input name="razorpayKeySecret" type="password" id="pw-razorpay-secret" maxlength="100"
            placeholder="<% if (shop.paymentSettings?.razorpay?.keySecret) { %>Leave blank to keep current secret<% } else { %>Enter your Razorpay key secret<% } %>" />
          <button type="button" class="pw-toggle" aria-label="Show password" onclick="togglePasswordVisibility('pw-razorpay-secret', this)">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </button>
        </div>
        <% if (shop.paymentSettings?.razorpay?.keySecret) { %>
          <p class="muted small">Leave blank to keep the existing secret.</p>
        <% } %>
      </label>
    </fieldset>

    <fieldset class="fieldset" data-gateway="easebuzz">
      <legend>Easebuzz Credentials</legend>

      <label>
        <span>Merchant Key</span>
        <input name="easebuzzMerchantKey" type="text" maxlength="100"
          value="<%= shop.paymentSettings?.easebuzz?.merchantKey || "" %>"
          placeholder="Easebuzz merchant key" />
      </label>

      <label>
        <span>Salt</span>
        <div class="pw-field">
          <input name="easebuzzSalt" type="password" id="pw-easebuzz-salt" maxlength="100"
            placeholder="<% if (shop.paymentSettings?.easebuzz?.salt) { %>Leave blank to keep current salt<% } else { %>Enter your Easebuzz salt<% } %>" />
          <button type="button" class="pw-toggle" aria-label="Show password" onclick="togglePasswordVisibility('pw-easebuzz-salt', this)">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </button>
        </div>
        <% if (shop.paymentSettings?.easebuzz?.salt) { %>
          <p class="muted small">Leave blank to keep the existing salt.</p>
        <% } %>
      </label>

      <label>
        <span>Environment</span>
        <select name="easebuzzEnv">
          <option value="test" <%= (shop.paymentSettings?.easebuzz?.env || "test") === "test" ? "selected" : "" %>>Test (sandbox)</option>
          <option value="prod" <%= shop.paymentSettings?.easebuzz?.env === "prod" ? "selected" : "" %>>Production (live)</option>
        </select>
      </label>
    </fieldset>

    <fieldset class="fieldset" data-gateway="phonepe">
      <legend>PhonePe Credentials</legend>

      <% if (shop.paymentConfigured && shop.paymentGateway === "phonepe") { %>
        <div class="flash flash--success">PhonePe is configured and active for this workspace.</div>
      <% } else { %>
        <div class="flash flash--info">Enter your PhonePe credentials to accept payments.</div>
      <% } %>

      <label>
        <span>Client ID</span>
        <input name="phonepeClientId" type="text" maxlength="100"
          value="<%= shop.paymentSettings?.phonepe?.clientId || "" %>"
          placeholder="PhonePe client ID" />
      </label>

      <label>
        <span>Client Secret</span>
        <div class="pw-field">
          <input name="phonepeClientSecret" type="password" id="pw-phonepe-secret" maxlength="200"
            placeholder="<% if (shop.paymentSettings?.phonepe?.clientSecret) { %>Leave blank to keep current client secret<% } else { %>Enter your PhonePe client secret<% } %>" />
          <button type="button" class="pw-toggle" aria-label="Show password" onclick="togglePasswordVisibility('pw-phonepe-secret', this)">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </button>
        </div>
        <% if (shop.paymentSettings?.phonepe?.clientSecret) { %>
          <p class="muted small">Leave blank to keep the existing client secret.</p>
        <% } %>
      </label>

      <label>
        <span>Client Version</span>
        <input name="phonepeClientVersion" type="text" maxlength="50"
          value="<%= shop.paymentSettings?.phonepe?.clientVersion || "" %>"
          placeholder="Client version from PhonePe dashboard" />
      </label>

      <label>
        <span>Environment</span>
        <select name="phonepeEnv">
          <option value="UAT" <%= (shop.paymentSettings?.phonepe?.env || "UAT") === "UAT" ? "selected" : "" %>>UAT (sandbox)</option>
          <option value="PROD" <%= shop.paymentSettings?.phonepe?.env === "PROD" ? "selected" : "" %>>Production (live)</option>
        </select>
      </label>
    </fieldset>

    <div class="row">
      <button class="btn" type="submit">Save payment settings</button>
      <a class="btn btn--outline" href="/editor/assets">Cancel</a>
    </div>

  </form>
</div>

<script>
  (function () {
    var select = document.getElementById("paymentGatewaySelect");
    if (!select) return;
    var sections = document.querySelectorAll("fieldset[data-gateway]");

    function sync() {
      var active = select.value;
      sections.forEach(function (section) {
        section.style.display = section.getAttribute("data-gateway") === active ? "" : "none";
      });
    }

    select.addEventListener("change", sync);
    sync();
  })();
</script>

<%- include("../partials/footer") %>
