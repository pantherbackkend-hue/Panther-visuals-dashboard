<%- include("../../partials/header", { pageTitle }) %>

<section class="admin-page-head">
  <div>
    <p class="eyebrow">Project workspace</p>
    <h1><%= project.projectName %></h1>
    <p class="muted">
      Client: <strong><%= project.client?.name || project.clientName || "" %></strong> &middot;
      <span class="tag tag--<%= getBadgeColor(project.status) %>"><%= formatStatus(project.status) %></span>
    </p>
  </div>
  <a class="btn btn--outline" href="/editor/projects">Back to projects</a>
</section>

<% var overdue = project.dueDate && new Date(project.dueDate) < new Date() && project.status !== "completed"; %>
<% if (overdue) { %>
  <div class="overdue-warning mb-16">
    <strong>Overdue</strong> &mdash; This project was due on <%= new Date(project.dueDate).toLocaleDateString("en-IN", { timeZone: "Asia/Kolkata" }) %>.
  </div>
<% } %>

<section class="admin-metrics">
  <article class="card admin-metric"><p class="muted small">Priority</p><h2><span class="priority-dot priority-dot--<%= project.priority %>"></span><span class="capitalize"><%= project.priority %></span></h2></article>
  <article class="card admin-metric"><p class="muted small">Amount</p><h2><%= formatMoney(project.payment?.amount || 0) %></h2></article>
  <article class="card admin-metric"><p class="muted small">Due</p><h2 class="<%= overdue ? '' : '' %>" style="<%= overdue ? 'color:var(--danger)' : '' %>"><%= project.dueDate ? new Date(project.dueDate).toLocaleDateString("en-IN") : "—" %></h2></article>
  <article class="card admin-metric"><p class="muted small">Versions</p><h2><%= project.submissions?.length || 0 %></h2></article>
</section>

<% if (project.status === "ongoing") { %>
  <div class="card admin-panel">
    <h2 class="h2 mt-0">Submit Work</h2>
    <form class="admin-form full-width" id="submit-form">
      <div class="form-group">
        <label for="driveLink">Drive Link <span class="required">*</span></label>
        <input type="url" id="driveLink" name="driveLink" placeholder="https://drive.google.com/..." required />
      </div>
      <div class="form-group">
        <label for="description">Description</label>
        <textarea id="description" name="description" rows="2" placeholder="What's in this submission?"></textarea>
      </div>
      <button class="btn" type="submit">Submit Version <%= (project.submissions?.length || 0) + 1 %></button>
    </form>
  </div>
<% } %>

<% if (project.submissions && project.submissions.length > 0) { %>
  <div class="card admin-panel">
    <h2 class="h2 mt-0">Submission History</h2>
    <div class="submission-list">
      <% project.submissions.slice().reverse().forEach(function(s) { %>
        <div class="submission-item">
          <div class="submission-item__head">
            <strong>Version <%= s.version %></strong>
            <span class="tag tag--ok">Submitted</span>
          </div>
          <div class="submission-item__meta">
            <span class="muted small"><%= new Date(s.submittedAt).toLocaleString("en-IN", { timeZone: "Asia/Kolkata" }) %></span>
          </div>
          <div class="submission-item__body">
            <p><a href="<%= s.driveLink %>" target="_blank" rel="noopener"><%= s.driveLink.length > 80 ? s.driveLink.slice(0, 80) + "..." : s.driveLink %></a></p>
            <% if (s.description) { %><p class="muted"><%= s.description %></p><% } %>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
<% } %>

<% if (project.feedback && project.feedback.length > 0) { %>
  <div class="card admin-panel">
    <h2 class="h2 mt-0">Feedback History</h2>
    <div class="feedback-list">
      <% project.feedback.slice().reverse().forEach(function(f) { %>
        <div class="feedback-item">
          <div class="feedback-item__head">
            <% if (f.versionRef) { %><strong>Version <%= f.versionRef %></strong><% } %>
            <span class="muted small"><%= new Date(f.createdAt).toLocaleString("en-IN", { timeZone: "Asia/Kolkata" }) %></span>
          </div>
          <div class="feedback-item__body">
            <% if (f.comment) { %><p><%= f.comment %></p><% } %>
            <% if (f.driveLink) { %><p><a href="<%= f.driveLink %>" target="_blank" rel="noopener">Reference link</a></p><% } %>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
<% } %>

<div class="card admin-panel">
    <h2 class="h2 mt-0">Details</h2>
  <div class="admin-detail-grid">
    <div><span>Drive Link</span><strong><% if (project.driveLink) { %><a href="<%= project.driveLink %>" target="_blank" rel="noopener"><%= project.driveLink.length > 60 ? project.driveLink.slice(0,60) + "..." : project.driveLink %></a><% } else { %><span class="muted">Not provided</span><% } %></strong></div>
    <% if (project.client?.email) { %><div><span>Client Email</span><strong><%= project.client.email %></strong></div><% } %>
    <% if (project.client?.phone) { %><div><span>Client Phone</span><strong><%= project.client.phone %></strong></div><% } %>
    <div><span>Payment Amount</span><strong><%= formatMoney(project.payment?.amount || 0) %></strong></div>
    <div><span>Payment Status</span><strong>
      <% if (project.payment?.status === "paid") { %><span class="tag tag--ok">Paid</span>
      <% } else if (project.payment?.status === "pending" && project.status === "completed") { %><span class="tag tag--pending">Awaiting Payment</span>
      <% } else { %><span class="muted">N/A</span><% } %>
    </strong></div>
    <div><span>Created</span><strong><%= new Date(project.createdAt).toLocaleString("en-IN", { timeZone: "Asia/Kolkata" }) %></strong></div>
    <% if (project.completedAt) { %><div><span>Completed</span><strong><%= new Date(project.completedAt).toLocaleString("en-IN", { timeZone: "Asia/Kolkata" }) %></strong></div><% } %>
    <% if (project.notes) { %><div class="overflow-auto" style="grid-column:1/-1"><span>Notes</span><strong style="white-space:pre-wrap"><%= project.notes %></strong></div><% } %>
  </div>
</div>

<div class="card admin-panel" id="timeline">
    <h2 class="h2 mt-0">Activity Timeline</h2>
  <% if (project.activityTimeline.length === 0) { %>
    <p class="muted">No activity recorded yet.</p>
  <% } else { %>
    <div class="timeline">
      <% project.activityTimeline.slice().reverse().forEach(function(entry) { %>
        <div class="timeline-item">
          <div class="timeline-marker"></div>
          <div class="timeline-content">
            <p class="timeline-action"><strong><%= entry.action %></strong></p>
            <p class="timeline-meta">
              by <%= entry.userName || "System" %>
              <% if (entry.previousStatus && entry.newStatus) { %>
                — <%= formatStatus(entry.previousStatus) %> → <%= formatStatus(entry.newStatus) %>
              <% } %>
            </p>
            <% if (entry.notes) { %><p class="timeline-notes"><%= entry.notes %></p><% } %>
            <p class="timeline-date muted small"><%= new Date(entry.createdAt).toLocaleString("en-IN", { timeZone: "Asia/Kolkata" }) %></p>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<script>
  (function () {
    var form = document.getElementById("submit-form");
    if (!form) return;

    form.addEventListener("submit", function (e) {
      e.preventDefault();
      var btn = form.querySelector("button[type=submit]");
      var driveLink = form.querySelector("[name=driveLink]").value.trim();
      var description = form.querySelector("[name=description]").value.trim();

      if (!driveLink) {
        showFormError(form, "Drive link is required.");
        return;
      }

      btn.disabled = true;
      btn.textContent = "Submitting...";

      fetch("/editor/projects/<%= project._id %>/submit", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ driveLink: driveLink, description: description }),
      })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (data.success) {
            location.reload();
          } else {
            showFormError(form, data.error || "Failed to submit.");
            btn.disabled = false;
            btn.textContent = "Submit Version <%= (project.submissions?.length || 0) + 1 %>";
          }
        })
        .catch(function () {
          showFormError(form, "Network error.");
          btn.disabled = false;
          btn.textContent = "Submit Version <%= (project.submissions?.length || 0) + 1 %>";
        });
    });

    function showFormError(form, msg) {
      var existing = form.querySelector(".alert-inline");
      if (!existing) {
        existing = document.createElement("div");
        existing.className = "alert-inline alert-inline--error is-visible";
        form.insertBefore(existing, form.querySelector("button"));
      } else {
        existing.classList.add("is-visible");
        existing.classList.remove("alert-inline--success");
        existing.classList.add("alert-inline--error");
      }
      existing.textContent = msg;
      setTimeout(function () { existing.classList.remove("is-visible"); }, 4000);
    }
  })();
</script>

<%- include("../../partials/footer") %>