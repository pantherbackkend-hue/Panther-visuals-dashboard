<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= pageTitle ? `${pageTitle} | Panther Corporation` : "Panther Corporation Dashboard" %></title>
    <link rel="icon" type="image/jpeg" href="/images/logo.jpeg" />
    <link rel="stylesheet" href="/styles.css" />
    <script src="/socket.io/socket.io.js"></script>
    <script src="/js/notification-manager.js"></script>
  </head>
  <body<%= currentUser ? ` data-role="${currentUser.role}" data-user-id="${currentUser.id}"` : "" %>>
    <div class="page-content">
      <header class="topbar">
        <div class="container topbar__inner">
          <div class="topbar__brand-row">
            <a class="brand" href="/"><img src="/images/logo.jpeg" alt="Panther Corporation" class="brand-logo" />Panther Corporation</a>
          </div>

          <nav id="main-nav" class="nav nav-main" aria-label="Main">
            <a class="nav__link" href="/workspaces">Workspaces</a>

            <% if (currentUser && currentUser.role === "client") { %>
              <a class="nav__link" href="/projects">Projects</a>
            <% } %>

            <% if (currentUser && (currentUser.role === "admin" || currentUser.role === "owner")) { %>
              <a class="nav__link" href="/admin">Dashboard</a>
              <a class="nav__link" href="/admin/projects">Projects</a>
            <% } %>

            <% if (currentUser && currentUser.role === "editor") { %>
              <%- include("./editor-nav") %>
            <% } %>

            <% if (currentUser) { %>
              <button type="button" class="nav__link notif-bell" data-notif-bell aria-label="Notifications">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                <span class="notif-badge" data-notif-badge style="display:none">0</span>
              </button>

              <div class="notif-dropdown" data-notif-dropdown>
                <div class="notif-header">
                  <strong>Notifications</strong>
                  <button class="btn btn--small btn--ghost" data-mark-all-read>Mark all read</button>
                </div>
                <ul class="notif-list" data-notif-list></ul>
              </div>

              <span class="nav__text nav-main__greet"><%= currentUser.name %></span>

              <form method="post" action="/logout" class="inline nav-main__logout">
                <button class="btn btn--ghost nav-main__logout-btn" type="submit">Logout</button>
              </form>
            <% } else { %>
              <a class="btn btn--ghost nav-main__auth" href="/login">Login</a>
              <a class="btn nav-main__auth" href="/signup">Sign up</a>
            <% } %>
          </nav>

          <button type="button" class="nav-toggle" data-nav-toggle aria-expanded="false" aria-controls="main-nav" aria-label="Open menu">&#9776;</button>
        </div>
      </header>

      <main class="container">
        <% if (flash?.success?.length) { %>
          <div class="flash flash--success">
            <%= flash.success[0] %>
            <% if (locals.flashSubtext) { %><br><%= flashSubtext %><% } %>
          </div>
        <% } %>

        <% if (flash?.error?.length) { %>
          <div class="flash flash--error"><%= flash.error[0] %></div>
        <% } %>
