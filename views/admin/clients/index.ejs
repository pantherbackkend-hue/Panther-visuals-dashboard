<%- include("../../partials/header", { pageTitle }) %>
<%- include("../partials/layout-start", { activeSection }) %>

<section class="admin-page-head">
  <div>
    <p class="eyebrow">Client management</p>
    <h1>Clients</h1>
    <p class="muted">Manage client profiles and reference materials.</p>
  </div>
  <div class="admin-actions">
    <a class="btn" href="/admin/clients/new">+ New Client</a>
  </div>
</section>

<div class="card admin-panel admin-toolbar">
  <form method="get" action="/admin/clients" class="admin-filter-bar">
    <label style="flex:1;min-width:180px">
      <span class="sr-only">Search</span>
      <input name="q" type="search" placeholder="Search by name, email, or channel..." value="<%= search || "" %>" />
    </label>
    <button class="btn" type="submit">Search</button>
    <a class="btn btn--outline" href="/admin/clients">Reset</a>
  </form>
</div>

<div class="card admin-panel">
  <% if (clients.length === 0) { %>
    <p class="muted">No clients found. <a href="/admin/clients/new">Create your first client</a>.</p>
  <% } else { %>
    <div style="overflow-x:auto">
      <table class="table" role="table">
        <thead>
          <tr>
            <th scope="col">Client Name</th>
            <th scope="col">Channel Name</th>
            <th scope="col">Email</th>
            <th scope="col">Projects</th>
            <th scope="col">Assets</th>
            <th scope="col">Created</th>
            <th scope="col">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% clients.forEach(function(c) { %>
            <tr>
              <td><strong><a class="admin-link" href="/admin/clients/<%= c._id %>"><%= c.name %></a></strong></td>
              <td><%= c.channelName || '<span class="muted">—</span>' %></td>
              <td><%= c.email || '<span class="muted">—</span>' %></td>
              <td><%= c.projectCount %></td>
              <td><%= c.assetCount %></td>
              <td><%= new Date(c.createdAt).toLocaleDateString("en-IN") %></td>
              <td>
                <div class="admin-actions">
                  <a class="btn btn--small btn--outline" href="/admin/clients/<%= c._id %>">View</a>
                  <a class="btn btn--small btn--outline" href="/admin/clients/<%= c._id %>/edit">Edit</a>
                  <form method="post" action="/admin/clients/<%= c._id %>/delete" class="inline" onsubmit="return confirm('Delete client &quot;<%= c.name %>&quot;? This cannot be undone if no projects reference this client.')">
                    <button class="btn btn--small btn--danger" type="submit">Delete</button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<%- include("../partials/layout-end") %>
<%- include("../../partials/footer") %>