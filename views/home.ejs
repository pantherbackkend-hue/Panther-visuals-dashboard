<%- include("partials/header", { pageTitle }) %>

<section class="hero hero--home">
  <div class="hero__content">
    <p class="hero__eyebrow">Panther Corporation</p>
    <h1>Professional Workflow Management for Creative Studios</h1>
    <p>Manage projects, editors, revisions, approvals and payments from one dashboard.</p>

    <% if (!currentUser) { %>
      <div class="hero__actions">
        <a class="btn" href="/login">Launch Dashboard</a>
      </div>
    <% } else { %>
      <div class="hero__panel">
        <p>Logged in as <strong><%= currentUser.role %></strong>.</p>
        <% if (currentUser.role === "client") { %>
          <div class="row">
            <a class="btn" href="/projects">My Projects</a>
          </div>
        <% } else if (currentUser.role === "editor") { %>
          <div class="row">
            <a class="btn" href="/editor/projects">My Projects</a>
            <a class="btn btn--outline" href="/editor/assets">My Assets</a>
          </div>
        <% } else if (currentUser.role === "admin" || currentUser.role === "owner") { %>
          <div class="row">
            <a class="btn" href="/admin/workspace">Open Admin Dashboard</a>
            <a class="btn btn--outline" href="/admin/projects">Projects</a>
            <a class="btn btn--outline" href="/admin/workspace">Workspace</a>
          </div>
        <% } %>
      </div>
    <% } %>
  </div>
</section>

<section class="features" aria-label="Panther Corporation features">
  <article class="feature-card">
    <span class="feature-card__icon" aria-hidden="true">P</span>
    <h2>Project Tracking</h2>
    <p>Centralised workflow engine with 12 statuses, revision history, and activity timeline.</p>
  </article>
  <article class="feature-card">
    <span class="feature-card__icon" aria-hidden="true">T</span>
    <h2>Team Management</h2>
    <p>Assign editors, check availability, and manage workloads across your studio.</p>
  </article>
  <article class="feature-card">
    <span class="feature-card__icon" aria-hidden="true">R</span>
    <h2>Revision Control</h2>
    <p>Track unlimited revision cycles per project with complete change history.</p>
  </article>
  <article class="feature-card">
    <span class="feature-card__icon" aria-hidden="true">$</span>
    <h2>Payment Tracking</h2>
    <p>Monitor payment status from pending through paid, integrated with multiple gateways.</p>
  </article>
</section>

<%- include("partials/footer") %>
