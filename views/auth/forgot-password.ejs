<%- include("../partials/header", { pageTitle, flashSubtext: "If you don't see the password reset email within a minute, please check your Spam folder." }) %>

<div class="auth-page">
  <div class="card auth-card">
    <h2 class="auth-card__title">Forgot Password</h2>
    <form method="post" action="/forgot-password" class="form">
      <label>
        <span>Email</span>
        <input name="email" type="email" required autocomplete="email" />
      </label>
      <button class="btn btn--full" type="submit">Send Reset Link</button>
    </form>
    <p class="auth-card__footer"><a href="/login">Back to login</a></p>
  </div>
</div>

<%- include("../partials/footer") %>
